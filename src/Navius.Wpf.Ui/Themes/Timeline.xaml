<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:timeline="clr-namespace:Navius.Wpf.Ui.Timeline">

    <Style TargetType="{x:Type timeline:NaviusTimeline}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timeline:NaviusTimeline}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Header = the rail (a NaviusTimelineDot, plus a NaviusTimelineConnector on every item but
         the last); Content = the NaviusTimelineContent title/description block. -->
    <Style TargetType="{x:Type timeline:NaviusTimelineItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timeline:NaviusTimelineItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ContentPresenter
                            Grid.Column="0"
                            ContentSource="Header"
                            HorizontalAlignment="Center"
                            Margin="0,2,12,0" />
                        <ContentPresenter Grid.Column="1" ContentSource="Content" Margin="0,0,0,16" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type timeline:NaviusTimelineDot}">
        <Setter Property="Background" Value="{DynamicResource Navius.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.PrimaryForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Primary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timeline:NaviusTimelineDot}">
                    <Border
                        Width="12"
                        Height="12"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="999">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Variant" Value="Outline">
                <Setter Property="Background" Value="{DynamicResource Navius.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Navius.Primary}" />
                <Setter Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="Variant" Value="Secondary">
                <Setter Property="Background" Value="{DynamicResource Navius.Secondary}" />
                <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
            </Trigger>
            <Trigger Property="Variant" Value="Destructive">
                <Setter Property="Background" Value="{DynamicResource Navius.Destructive}" />
                <Setter Property="Foreground" Value="{DynamicResource Navius.DestructiveForeground}" />
            </Trigger>
            <Trigger Property="Variant" Value="Muted">
                <Setter Property="Background" Value="{DynamicResource Navius.Muted}" />
                <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type timeline:NaviusTimelineConnector}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timeline:NaviusTimelineConnector}">
                    <Border Width="1" Background="{DynamicResource Navius.Border}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type timeline:NaviusTimelineTitle}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timeline:NaviusTimelineTitle}">
                    <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="{TemplateBinding FontSize}" TextElement.FontWeight="{TemplateBinding FontWeight}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type timeline:NaviusTimelineDescription}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timeline:NaviusTimelineDescription}">
                    <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="{TemplateBinding FontSize}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
