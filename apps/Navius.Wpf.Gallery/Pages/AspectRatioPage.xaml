<UserControl x:Class="Navius.Wpf.Gallery.Pages.AspectRatioPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/AspectRatio.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="AspectRatio"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="420"
                   Text="Constrains its content to a fixed width:height ratio; width drives the computed height."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <TextBlock Text="16:9" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusAspectRatio AutomationProperties.AutomationId="AspectRatioDemo"
                                   Width="320" Ratio="1.7777777778" Margin="0,0,0,20">
            <Border Background="{DynamicResource Navius.Secondary}" BorderBrush="{DynamicResource Navius.Border}" BorderThickness="1">
                <TextBlock Text="16:9" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource Navius.SecondaryForeground}" />
            </Border>
        </navius:NaviusAspectRatio>

        <TextBlock Text="1:1" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusAspectRatio AutomationProperties.AutomationId="SquareAspectRatio"
                                   Width="160" Ratio="1" Margin="0,0,0,20">
            <Border Background="{DynamicResource Navius.Secondary}" BorderBrush="{DynamicResource Navius.Border}" BorderThickness="1">
                <TextBlock Text="1:1" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource Navius.SecondaryForeground}" />
            </Border>
        </navius:NaviusAspectRatio>

        <TextBlock Text="4:3" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusAspectRatio AutomationProperties.AutomationId="FourThreeAspectRatio"
                                   Width="240" Ratio="1.3333333333">
            <Border Background="{DynamicResource Navius.Secondary}" BorderBrush="{DynamicResource Navius.Border}" BorderThickness="1">
                <TextBlock Text="4:3" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource Navius.SecondaryForeground}" />
            </Border>
        </navius:NaviusAspectRatio>
    </StackPanel>
</UserControl>
