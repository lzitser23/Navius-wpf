<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls"
    xmlns:timeInput="clr-namespace:Navius.Wpf.Primitives.Controls.TimeInput"
    xmlns:timePicker="clr-namespace:Navius.Wpf.Primitives.Controls.TimePicker">

    <!--
        Not merged into Generic.xaml (out of scope for this wave; same precedent as
        Themes/Select.xaml). Pages that use TimePicker merge this dictionary themselves, alongside
        Themes/DateInput.xaml (shared NaviusFieldSegment) and Themes/TimeInput.xaml (the embedded
        PART_Input's own style):
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/DateInput.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/TimeInput.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/TimePicker.xaml" />

        Hard rule for this wave: hairline borders, no DropShadowEffect, one-ink brand. Columns are
        native ListBox (role="listbox" via ListBoxAutomationPeer, roving tabindex + TextSearch
        typeahead for free; see NaviusTimePicker.cs's remarks and the family's "WPF implementation
        notes" for the resulting contract deltas vs. the web's custom column/option parts).
    -->

    <!-- One column's option row (role="option" via native ListBoxItem/ListBoxItemAutomationPeer). -->
    <Style x:Key="Navius.TimePickerColumnItem" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border
                        x:Name="Bd"
                        Background="Transparent"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Navius.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Navius.AccentForeground}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Navius.Muted}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- One column (role="listbox"): a plain, scrollable, borderless ListBox. -->
    <Style x:Key="Navius.TimePickerColumn" TargetType="{x:Type ListBox}">
        <Setter Property="Width" Value="52" />
        <Setter Property="MaxHeight" Value="220" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Navius.TimePickerColumnItem}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="TextSearch.TextPath" Value="Text" />
    </Style>

    <Style TargetType="{x:Type timePicker:NaviusTimePicker}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timePicker:NaviusTimePicker}">
                    <Grid x:Name="Root">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <timeInput:NaviusTimeInput
                            x:Name="PART_Input"
                            Grid.Column="0"
                            Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                            Granularity="{Binding Granularity, RelativeSource={RelativeSource TemplatedParent}}"
                            HourCycle="{Binding HourCycle, RelativeSource={RelativeSource TemplatedParent}}"
                            MinuteStep="{Binding MinuteStep, RelativeSource={RelativeSource TemplatedParent}}"
                            SecondStep="{Binding SecondStep, RelativeSource={RelativeSource TemplatedParent}}"
                            Culture="{Binding Culture, RelativeSource={RelativeSource TemplatedParent}}" />

                        <ToggleButton
                            x:Name="PART_Trigger"
                            Grid.Column="1"
                            Margin="4,0,0,0"
                            Width="28" Height="28"
                            IsChecked="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                            AutomationProperties.Name="Open time picker">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border
                                        Background="{DynamicResource Navius.Background}"
                                        BorderBrush="{DynamicResource Navius.Input}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Navius.Radius.Control}">
                                        <Path
                                            Width="14" Height="14"
                                            Stretch="Uniform"
                                            Data="M 7,1 A 6,6 0 1 1 6.99,1 M 7,3.5 L 7,7 L 9.5,8.5"
                                            Stroke="{DynamicResource Navius.Foreground}"
                                            StrokeThickness="1.2"
                                            StrokeStartLineCap="Round"
                                            StrokeEndLineCap="Round"
                                            StrokeLineJoin="Round" />
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <controls:NaviusAnchoredPopup
                            x:Name="PART_Popup"
                            Anchor="{Binding ElementName=Root}"
                            Side="Bottom"
                            Align="Start"
                            SideOffset="6"
                            IsOpen="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border
                                x:Name="PART_PopupContent"
                                Padding="4"
                                Background="{DynamicResource Navius.Popover}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Navius.Radius.Control}"
                                FocusVisualStyle="{x:Null}">
                                <StackPanel Orientation="Horizontal">
                                    <ListBox x:Name="PART_HourColumn" Style="{StaticResource Navius.TimePickerColumn}" />
                                    <ListBox x:Name="PART_MinuteColumn" Style="{StaticResource Navius.TimePickerColumn}" />
                                    <ListBox x:Name="PART_SecondColumn" Style="{StaticResource Navius.TimePickerColumn}" />
                                    <ListBox x:Name="PART_DayPeriodColumn" Style="{StaticResource Navius.TimePickerColumn}" Width="44" />
                                </StackPanel>
                            </Border>
                        </controls:NaviusAnchoredPopup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
