<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:badge="clr-namespace:Navius.Wpf.Ui.Badge">

    <!-- The pill radius is half the border's rendered height (NaviusPillRadiusConverter), so the
         ends stay perfectly circular at any font size. An oversized constant is not an option:
         WPF normalizes a CornerRadius that exceeds half a dimension independently per axis,
         turning the whole border into an ellipse instead of a capsule with straight sides. -->

    <Style TargetType="{x:Type badge:NaviusBadge}">
        <Setter Property="Background" Value="{DynamicResource Navius.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.PrimaryForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,1" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type badge:NaviusBadge}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={x:Static badge:NaviusPillRadiusConverter.Instance}}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Variant" Value="Secondary">
                <Setter Property="Background" Value="{DynamicResource Navius.Secondary}" />
                <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Navius.Secondary}" />
            </Trigger>
            <Trigger Property="Variant" Value="Outline">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Navius.Border}" />
            </Trigger>
            <Trigger Property="Variant" Value="Destructive">
                <Setter Property="Background" Value="{DynamicResource Navius.Destructive}" />
                <Setter Property="Foreground" Value="{DynamicResource Navius.DestructiveForeground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Navius.Destructive}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
