<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls">

    <Style TargetType="{x:Type controls:NaviusSwitch}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Background" Value="{DynamicResource Navius.Input}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusSwitch}">
                    <Border
                        x:Name="Track"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="2"
                        CornerRadius="11">
                        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Ellipse
                                x:Name="PART_Thumb"
                                Width="18" Height="18"
                                Margin="2,0"
                                Fill="{DynamicResource Navius.Card}">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- data-checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource Navius.Primary}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="18" Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="0" Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- data-readonly -->
                        <Trigger Property="controls:NaviusSwitch.ReadOnly" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.8" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
