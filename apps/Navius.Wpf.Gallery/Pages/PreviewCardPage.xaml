<UserControl x:Class="Navius.Wpf.Gallery.Pages.PreviewCardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use
                     NaviusPreviewCard merge this dictionary themselves. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/PreviewCard.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="PreviewCard"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="420"
                   Text="Hover or Tab to the link to open its preview after a short delay. Moving the pointer from the link into the card keeps it open; leaving both closes it after a grace delay."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <navius:NaviusPreviewCard
            HorizontalAlignment="Left"
            Content="@navius"
            OpenDelay="400"
            CloseDelay="200">
            <navius:NaviusPreviewCard.PreviewContent>
                <StackPanel MaxWidth="240">
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="Navius" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource Navius.MutedForeground}"
                        Text="An honest WPF port of the Navius primitives, built on Base UI parity contracts."
                        TextWrapping="Wrap" />
                </StackPanel>
            </navius:NaviusPreviewCard.PreviewContent>
        </navius:NaviusPreviewCard>
    </StackPanel>
</UserControl>
