<UserControl x:Class="Navius.Wpf.Gallery.Pages.LabelPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <StackPanel Margin="24">
        <TextBlock Text="Label" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Associated with a control (For, click-to-focus)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusLabel For="EmailInput" Content="Email address" Margin="0,0,0,4" />
        <TextBox x:Name="EmailInput" Width="220" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Standalone (no associated control)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusLabel Content="Standalone label" />
    </StackPanel>
</UserControl>
