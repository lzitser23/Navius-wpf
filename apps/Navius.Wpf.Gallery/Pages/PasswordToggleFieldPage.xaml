<UserControl x:Class="Navius.Wpf.Gallery.Pages.PasswordToggleFieldPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ptf="clr-namespace:Navius.Wpf.Primitives.Controls.PasswordToggleField;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/PasswordToggleField.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="PasswordToggleField" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Default (Icon text swaps with revealed state)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <ptf:NaviusPasswordToggleField AutomationProperties.AutomationId="DefaultToggleField"
                                       HorizontalAlignment="Left" Width="280" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ptf:NaviusPasswordToggleFieldInput Grid.Column="0" />
                <ptf:NaviusPasswordToggleFieldToggle Grid.Column="1" Margin="4,0,0,0">
                    <ptf:NaviusPasswordToggleFieldIcon VisibleContent="Hide" HiddenContent="Show" />
                </ptf:NaviusPasswordToggleFieldToggle>
            </Grid>
        </ptf:NaviusPasswordToggleField>

        <TextBlock Text="Starts revealed (Visible=True)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <ptf:NaviusPasswordToggleField AutomationProperties.AutomationId="RevealedToggleField"
                                       Visible="True" HorizontalAlignment="Left" Width="280" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ptf:NaviusPasswordToggleFieldInput Grid.Column="0" />
                <ptf:NaviusPasswordToggleFieldToggle Grid.Column="1" Margin="4,0,0,0">
                    <ptf:NaviusPasswordToggleFieldIcon VisibleContent="Hide" HiddenContent="Show" />
                </ptf:NaviusPasswordToggleFieldToggle>
            </Grid>
        </ptf:NaviusPasswordToggleField>

        <TextBlock Text="Slot (arbitrary content swap next to the field)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <ptf:NaviusPasswordToggleField AutomationProperties.AutomationId="SlotToggleField"
                                       HorizontalAlignment="Left" Width="280">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ptf:NaviusPasswordToggleFieldInput Grid.Column="0" />
                    <ptf:NaviusPasswordToggleFieldToggle Grid.Column="1" Margin="4,0,0,0">
                        <ptf:NaviusPasswordToggleFieldIcon VisibleContent="Hide" HiddenContent="Show" />
                    </ptf:NaviusPasswordToggleFieldToggle>
                </Grid>
                <ptf:NaviusPasswordToggleFieldSlot>
                    <ptf:NaviusPasswordToggleFieldSlot.VisibleContent>
                        <TextBlock Text="Anyone near your screen can read this."
                                   Foreground="{DynamicResource Navius.Destructive}" FontSize="12" />
                    </ptf:NaviusPasswordToggleFieldSlot.VisibleContent>
                    <ptf:NaviusPasswordToggleFieldSlot.HiddenContent>
                        <TextBlock Text="Your password is hidden."
                                   Foreground="{DynamicResource Navius.MutedForeground}" FontSize="12" />
                    </ptf:NaviusPasswordToggleFieldSlot.HiddenContent>
                </ptf:NaviusPasswordToggleFieldSlot>
            </StackPanel>
        </ptf:NaviusPasswordToggleField>
    </StackPanel>
</UserControl>
