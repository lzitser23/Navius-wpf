<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:breadcrumb="clr-namespace:Navius.Wpf.Ui.Breadcrumb">

    <!--
        Not merged into Generic.xaml (the orchestrator owns that file). Consumers merge this
        dictionary themselves, same precedent as Navius.Wpf.Primitives' Themes/Autocomplete.xaml
        and Themes/Dialog.xaml:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Breadcrumb.xaml" />
    -->

    <Style TargetType="{x:Type breadcrumb:NaviusBreadcrumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type breadcrumb:NaviusBreadcrumb}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type breadcrumb:NaviusBreadcrumbItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="2,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type breadcrumb:NaviusBreadcrumbItem}">
                    <Border x:Name="Root" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="{DynamicResource Navius.Radius.Small}">
                        <ContentPresenter VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCurrentPage" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsCurrentPage" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsCurrentPage" Value="False" />
                                <Condition Property="IsFocused" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type breadcrumb:NaviusBreadcrumbSeparator}">
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type breadcrumb:NaviusBreadcrumbSeparator}">
                    <Path
                        Data="M 0,0 L 4,4 L 0,8"
                        VerticalAlignment="Center"
                        Stroke="{DynamicResource Navius.MutedForeground}"
                        StrokeThickness="1.4"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
