<UserControl x:Class="Navius.Wpf.Gallery.Pages.CollapsiblePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:collapsible="clr-namespace:Navius.Wpf.Primitives.Controls.Collapsible;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Self-contained: merges its own family theme directly, since Generic.xaml
                     is owned by a concurrent wave this cycle and is not touched here. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Collapsible.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <TextBlock Text="Collapsible" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Default (closed)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <collapsible:NaviusCollapsible Margin="0,0,0,24" Width="280" HorizontalAlignment="Left">
            <StackPanel>
                <collapsible:NaviusCollapsibleTrigger Content="What is Navius.Wpf?" HorizontalAlignment="Stretch" />
                <collapsible:NaviusCollapsiblePanel>
                    <TextBlock TextWrapping="Wrap" Margin="4,8,4,0"
                               Foreground="{DynamicResource Navius.Foreground}"
                               Text="A WPF parity port of the Navius primitive library." />
                </collapsible:NaviusCollapsiblePanel>
            </StackPanel>
        </collapsible:NaviusCollapsible>

        <TextBlock Text="Open by default, kept mounted while closed" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <collapsible:NaviusCollapsible Open="True" Width="280" HorizontalAlignment="Left" Margin="0,0,0,24">
            <StackPanel>
                <collapsible:NaviusCollapsibleTrigger Content="Details" HorizontalAlignment="Stretch" />
                <collapsible:NaviusCollapsiblePanel KeepMounted="True">
                    <TextBlock TextWrapping="Wrap" Margin="4,8,4,0"
                               Foreground="{DynamicResource Navius.Foreground}"
                               Text="This panel stays mounted (only Visibility toggles) while closed." />
                </collapsible:NaviusCollapsiblePanel>
            </StackPanel>
        </collapsible:NaviusCollapsible>

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <collapsible:NaviusCollapsible IsEnabled="False" Width="280" HorizontalAlignment="Left">
            <StackPanel>
                <collapsible:NaviusCollapsibleTrigger Content="Can't open me" HorizontalAlignment="Stretch" />
                <collapsible:NaviusCollapsiblePanel>
                    <TextBlock Text="Unreachable." Margin="4,8,4,0" />
                </collapsible:NaviusCollapsiblePanel>
            </StackPanel>
        </collapsible:NaviusCollapsible>
    </StackPanel>
</UserControl>
