<UserControl x:Class="Navius.Wpf.Gallery.Pages.DateInputPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dateInput="clr-namespace:Navius.Wpf.Primitives.Controls.DateInput;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/DateInput.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="DateInput" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <!-- DateOnly?/TimeOnly? have no XAML TypeConverter (they postdate WPF); values for the
             pre-filled demos below are set from code-behind rather than as string attributes. -->

        <TextBlock Text="Default (day granularity; type digits or Up/Down per segment)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <dateInput:NaviusDateInput x:Name="DefaultInput"
                                    AutomationProperties.AutomationId="DateInputDemo"
                                    HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Pre-filled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <dateInput:NaviusDateInput x:Name="FilledInput"
                                    AutomationProperties.AutomationId="FilledDateInput"
                                    HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Month granularity" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <dateInput:NaviusDateInput x:Name="MonthGranularityInput"
                                    AutomationProperties.AutomationId="MonthGranularityDateInput"
                                    Granularity="month" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Force leading zeros" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <dateInput:NaviusDateInput x:Name="LeadingZerosInput"
                                    AutomationProperties.AutomationId="LeadingZerosDateInput"
                                    ForceLeadingZeros="True" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Read-only" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <dateInput:NaviusDateInput x:Name="ReadOnlyInput"
                                    AutomationProperties.AutomationId="ReadOnlyDateInput"
                                    ReadOnly="True" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <dateInput:NaviusDateInput x:Name="DisabledInput"
                                    AutomationProperties.AutomationId="DisabledDateInput"
                                    IsEnabled="False" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
