<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:inputGroup="clr-namespace:Navius.Wpf.Ui.InputGroup">

    <!--
        Not merged into Generic.xaml (the orchestrator owns that file). Consumers merge this
        dictionary themselves:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/InputGroup.xaml" />
    -->

    <Style TargetType="{x:Type inputGroup:NaviusInputGroup}">
        <Setter Property="Background" Value="{DynamicResource Navius.Popover}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Input}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type inputGroup:NaviusInputGroup}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter
                                x:Name="Leading"
                                Grid.Column="0"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding LeadingContent}"
                                TextElement.Foreground="{DynamicResource Navius.MutedForeground}" />

                            <TextBox
                                x:Name="PART_Input"
                                Grid.Column="1"
                                Padding="10,7"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                CaretBrush="{DynamicResource Navius.Foreground}"
                                Foreground="{TemplateBinding Foreground}"
                                IsReadOnly="{TemplateBinding IsReadOnly}"
                                Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                x:Name="PlaceholderText"
                                Grid.Column="1"
                                Margin="11,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Navius.MutedForeground}"
                                IsHitTestVisible="False"
                                Text="{TemplateBinding Placeholder}"
                                Visibility="Collapsed" />

                            <ContentPresenter
                                x:Name="Trailing"
                                Grid.Column="2"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding TrailingContent}"
                                TextElement.Foreground="{DynamicResource Navius.MutedForeground}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger SourceName="PART_Input" Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <Trigger Property="LeadingContent" Value="{x:Null}">
                            <Setter TargetName="Leading" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="TrailingContent" Value="{x:Null}">
                            <Setter TargetName="Trailing" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
