<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:buttonGroup="clr-namespace:Navius.Wpf.Ui.ButtonGroup">

    <!--
        Not merged into Generic.xaml (the orchestrator owns that file). Consumers merge this
        dictionary themselves:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/ButtonGroup.xaml" />
    -->

    <buttonGroup:RoundedClipConverter x:Key="RoundedClipConverter" />

    <Style TargetType="{x:Type buttonGroup:NaviusButtonGroup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type buttonGroup:NaviusButtonGroup}">
                    <Border
                        x:Name="Root"
                        Background="{DynamicResource Navius.Popover}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        SnapsToDevicePixels="True">
                        <Grid x:Name="ClipHost">
                            <Grid.Clip>
                                <MultiBinding Converter="{StaticResource RoundedClipConverter}">
                                    <Binding ElementName="ClipHost" Path="ActualWidth" />
                                    <Binding ElementName="ClipHost" Path="ActualHeight" />
                                    <Binding ElementName="Root" Path="CornerRadius" />
                                </MultiBinding>
                            </Grid.Clip>
                            <ItemsPresenter />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="{Binding Orientation, RelativeSource={RelativeSource AncestorType={x:Type buttonGroup:NaviusButtonGroup}}}" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type buttonGroup:NaviusButtonGroupItem}">
        <Setter Property="Background" Value="{DynamicResource Navius.Popover}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Border}" />
        <Setter Property="BorderThickness" Value="1,1,0,1" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type buttonGroup:NaviusButtonGroupItem}">
                    <Border
                        x:Name="Bg"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Navius.Muted}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- DataTrigger + Binding, not a property Trigger: a Trigger.Property/Condition.Property
                 referencing an attached DP through a custom clr-namespace prefix fails to compile
                 here (BAML's deferred-block namespace table only picks up prefixes it sees used as
                 element/type markup, not embedded in a property-path string), so this is expressed
                 as a Binding path instead, which resolves the same "(prefix:Type.Property)" syntax
                 at runtime. -->
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <Binding RelativeSource="{RelativeSource Self}" Path="(buttonGroup:NaviusButtonGroup.IsLastItem)" />
                </DataTrigger.Binding>
                <Setter Property="BorderThickness" Value="1" />
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Value="Vertical">
                        <Condition.Binding>
                            <Binding RelativeSource="{RelativeSource Self}" Path="(buttonGroup:NaviusButtonGroup.Orientation)" />
                        </Condition.Binding>
                    </Condition>
                    <Condition Value="False">
                        <Condition.Binding>
                            <Binding RelativeSource="{RelativeSource Self}" Path="(buttonGroup:NaviusButtonGroup.IsLastItem)" />
                        </Condition.Binding>
                    </Condition>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderThickness" Value="1,1,1,0" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
