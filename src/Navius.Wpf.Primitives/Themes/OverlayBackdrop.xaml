<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:overlays="clr-namespace:Navius.Wpf.Primitives.Overlays">

    <!--
        Not merged into Generic.xaml (out of scope for this change: another family owns that
        file). Consumers that use OverlayBackdrop must merge this dictionary themselves, e.g.
        in the hosting page's own Resources:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/OverlayBackdrop.xaml" />
    -->
    <Style TargetType="{x:Type overlays:OverlayBackdrop}">
        <Setter Property="Background" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type overlays:OverlayBackdrop}">
                    <Border Background="{TemplateBinding Background}" Opacity="0.4" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
