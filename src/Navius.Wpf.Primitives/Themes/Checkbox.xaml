<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls.Checkbox">

    <Style TargetType="{x:Type controls:NaviusCheckboxIndicator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusCheckboxIndicator}">
                    <Grid>
                        <Path x:Name="CheckGlyph"
                              Data="M 1,5 L 4,8 L 9,1"
                              Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Visibility="Collapsed" />
                        <Rectangle x:Name="IndeterminateGlyph"
                                   Width="8" Height="1.6"
                                   Fill="{TemplateBinding Foreground}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="IndeterminateGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NaviusCheckbox}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusCheckbox}">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box"
                                Width="16" Height="16"
                                Background="{DynamicResource Navius.Background}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Navius.Radius.Small}">
                            <controls:NaviusCheckboxIndicator
                                IsChecked="{TemplateBinding IsChecked}"
                                Foreground="{DynamicResource Navius.PrimaryForeground}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ContentPresenter
                            Margin="8,0,0,0"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <!-- data-checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Navius.Primary}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Navius.Primary}" />
                        </Trigger>
                        <!-- data-indeterminate -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Navius.Primary}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Navius.Primary}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NaviusCheckboxGroup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusCheckboxGroup}">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
