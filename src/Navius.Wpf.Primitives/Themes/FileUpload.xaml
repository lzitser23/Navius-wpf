<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
    xmlns:fileupload="clr-namespace:Navius.Wpf.Primitives.Controls.FileUpload">

    <!--
        Not merged into Generic.xaml (out of scope: another family owns that file). Pages that use
        NaviusFileUpload merge this dictionary themselves, e.g.:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/FileUpload.xaml" />

        One-ink brand: hairline borders, no shadows. The dropzone is a real Button (focus +
        Enter/Space + Invoke pattern for free) restyled flat with a dashed hairline; data-dragging
        maps to the IsDragging trigger.
    -->

    <!-- One file row: name + size + remove (the web's Item/ItemName/ItemSize/ItemDelete parts). -->
    <DataTemplate x:Key="Navius.FileUpload.DefaultItem" DataType="{x:Type fileupload:FileEntry}">
        <Border
            Margin="0,0,0,4"
            Padding="8,6"
            Background="{DynamicResource Navius.Card}"
            BorderBrush="{DynamicResource Navius.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Navius.Radius.Small}">
            <DockPanel LastChildFill="True">
                <Button
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Padding="2,0"
                    VerticalAlignment="Center"
                    automation:AutomationProperties.Name="{Binding Name, StringFormat='Remove {0}'}"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{x:Static fileupload:NaviusFileUpload.RemoveFileCommand}"
                    CommandParameter="{Binding}"
                    Content="&#x2715;"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    Foreground="{DynamicResource Navius.MutedForeground}" />
                <TextBlock
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource Navius.MutedForeground}"
                    Text="{Binding SizeText}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource Navius.Foreground}"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </DataTemplate>

    <Style TargetType="{x:Type fileupload:NaviusFileUpload}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type fileupload:NaviusFileUpload}">
                    <StackPanel x:Name="Root">
                        <Button
                            x:Name="PART_Dropzone"
                            automation:AutomationProperties.Name="{TemplateBinding DropzoneText}"
                            Background="{DynamicResource Navius.Background}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="DropzoneBorder"
                                        Padding="24,20"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{DynamicResource Navius.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource Navius.Radius.Card}"
                                        SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="DropzoneBorder" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock
                                Foreground="{DynamicResource Navius.MutedForeground}"
                                Text="{Binding DropzoneText, RelativeSource={RelativeSource TemplatedParent}}"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </Button>

                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <Button
                                x:Name="PART_Browse"
                                Padding="10,5"
                                Background="{DynamicResource Navius.Card}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                Content="Browse files"
                                Cursor="Hand"
                                Foreground="{DynamicResource Navius.Foreground}" />
                            <Button
                                x:Name="PART_Clear"
                                Margin="8,0,0,0"
                                Padding="10,5"
                                Background="Transparent"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                Content="Clear all"
                                Cursor="Hand"
                                Foreground="{DynamicResource Navius.MutedForeground}" />
                        </StackPanel>

                        <ItemsControl
                            x:Name="PART_List"
                            Margin="0,8,0,0"
                            ItemTemplate="{StaticResource Navius.FileUpload.DefaultItem}"
                            ItemsSource="{TemplateBinding Files}" />

                        <!-- The polite status live region (the web's hidden role=status div). Kept
                             visible here as muted helper text; LiveSetting drives announcements. -->
                        <TextBlock
                            x:Name="PART_Status"
                            Margin="0,4,0,0"
                            automation:AutomationProperties.LiveSetting="Polite"
                            FontSize="11"
                            Foreground="{DynamicResource Navius.MutedForeground}"
                            Text="{TemplateBinding StatusText}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <!-- data-dragging: the hover-with-files affordance. -->
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="PART_Dropzone" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <!-- data-invalid: the most recent selection produced a rejection. -->
                        <Trigger Property="Invalid" Value="True">
                            <Setter TargetName="PART_Status" Property="Foreground" Value="{DynamicResource Navius.Destructive}" />
                        </Trigger>
                        <Trigger Property="IsFileListEmpty" Value="True">
                            <Setter TargetName="PART_Clear" Property="IsEnabled" Value="False" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
