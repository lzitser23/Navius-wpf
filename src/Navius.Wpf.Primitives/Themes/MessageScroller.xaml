<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ms="clr-namespace:Navius.Wpf.Primitives.Controls.MessageScroller">

    <!-- Not merged into Generic.xaml (out of scope for this family; Toast.xaml sets the same
         precedent). Consumers merge this dictionary themselves, see MessageScrollerPage.xaml. -->

    <Style x:Key="Navius.MessageScroller.JumpToLatestButtonStyle" TargetType="{x:Type ButtonBase}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="{DynamicResource Navius.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.PrimaryForeground}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Margin" Value="0,0,0,16" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource Navius.Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.9" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ms:NaviusMessageScroller}">
        <Setter Property="Background" Value="{DynamicResource Navius.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ms:NaviusMessageScroller}">
                    <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <!-- CanContentScroll="False": the engine's math is pixel-based (VerticalOffset/
                             ExtentHeight/ViewportHeight), which requires the ScrollViewer's physical
                             scrolling mode rather than item-logical scrolling. -->
                        <ScrollViewer
                            x:Name="PART_ScrollViewer"
                            CanContentScroll="False"
                            HorizontalScrollBarVisibility="Disabled"
                            Padding="{TemplateBinding Padding}"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>

                        <Button
                            x:Name="PART_JumpToLatestButton"
                            AutomationProperties.AutomationId="MessageScrollerJumpToLatestButton"
                            AutomationProperties.Name="Jump to latest"
                            Style="{StaticResource Navius.MessageScroller.JumpToLatestButtonStyle}"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="New messages" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    Text="{Binding NewMessageCount, RelativeSource={RelativeSource TemplatedParent}, StringFormat='({0})'}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
