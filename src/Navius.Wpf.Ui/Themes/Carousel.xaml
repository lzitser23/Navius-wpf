<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:carousel="clr-namespace:Navius.Wpf.Ui.Carousel">

    <!--
        Not merged into Generic.xaml (the orchestrator owns that file). Consumers merge this
        dictionary themselves:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Carousel.xaml" />
    -->

    <carousel:CarouselDotConverter x:Key="CarouselDotConverter" />
    <carousel:CarouselSlideNameConverter x:Key="CarouselSlideNameConverter" />

    <Style x:Key="Navius.Carousel.NavButton" TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Background" Value="{DynamicResource Navius.Popover}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Navius.Muted}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type carousel:NaviusCarousel}">
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type carousel:NaviusCarousel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Background="{DynamicResource Navius.Card}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Navius.Radius.Card}"
                            ClipToBounds="True">
                            <Grid>
                                <ItemsPresenter />

                                <Button
                                    Style="{StaticResource Navius.Carousel.NavButton}"
                                    AutomationProperties.Name="Previous slide"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="10,0"
                                    Command="{x:Static carousel:NaviusCarousel.PreviousCommand}">
                                    <Path Data="M 5,0 L 1,4 L 5,8" Stroke="{DynamicResource Navius.Foreground}" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                </Button>

                                <Button
                                    Style="{StaticResource Navius.Carousel.NavButton}"
                                    AutomationProperties.Name="Next slide"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="10,0"
                                    Command="{x:Static carousel:NaviusCarousel.NextCommand}">
                                    <Path Data="M 1,0 L 5,4 L 1,8" Stroke="{DynamicResource Navius.Foreground}" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                </Button>
                            </Grid>
                        </Border>

                        <ItemsControl
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Focusable="False"
                            ItemsSource="{Binding Items, RelativeSource={RelativeSource TemplatedParent}}"
                            AlternationCount="{Binding Items.Count, RelativeSource={RelativeSource TemplatedParent}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        x:Name="Dot"
                                        AutomationProperties.Name="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource CarouselSlideNameConverter}}"
                                        Width="16" Height="16"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{x:Static carousel:NaviusCarousel.GoToSlideCommand}"
                                        CommandTarget="{Binding RelativeSource={RelativeSource AncestorType={x:Type carousel:NaviusCarousel}}}">
                                        <Button.CommandParameter>
                                            <Binding RelativeSource="{RelativeSource AncestorType=ContentPresenter}" Path="(ItemsControl.AlternationIndex)" />
                                        </Button.CommandParameter>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid Background="{TemplateBinding Background}">
                                                    <Ellipse x:Name="Indicator" Width="7" Height="7" Fill="{DynamicResource Navius.Muted}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Tag" Value="Selected">
                                                        <Setter TargetName="Indicator" Property="Fill" Value="{DynamicResource Navius.Foreground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource CarouselDotConverter}">
                                                                <Binding RelativeSource="{RelativeSource AncestorType=ContentPresenter}" Path="(ItemsControl.AlternationIndex)" />
                                                                <Binding Path="SelectedIndex" RelativeSource="{RelativeSource AncestorType={x:Type carousel:NaviusCarousel}}" />
                                                            </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Tag" Value="Selected" />
                                                    <Setter Property="AutomationProperties.ItemStatus" Value="current" />
                                                </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="FrameworkElement">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="IsHitTestVisible" Value="False" />
                    <Setter Property="Focusable" Value="False" />
                    <Style.Triggers>
                        <Trigger Property="Selector.IsSelected" Value="True">
                            <Setter Property="IsHitTestVisible" Value="True" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=(Selector.IsSelected)}" Value="True" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type carousel:NaviusCarousel}}, Path=ShouldAnimate}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Opacity" Value="1" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
