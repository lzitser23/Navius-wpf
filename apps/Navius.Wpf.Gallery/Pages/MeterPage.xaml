<UserControl x:Class="Navius.Wpf.Gallery.Pages.MeterPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Meter.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Meter"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="420"
                   Text="A static, determinate readout (not a progress bar): disk usage, a score, a gauge. Never indeterminate."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <TextBlock Text="30 of 100" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusMeter AutomationProperties.AutomationId="LowMeter"
                             Width="240" HorizontalAlignment="Left" Value="30" Margin="0,0,0,20" />

        <TextBlock Text="Full" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusMeter AutomationProperties.AutomationId="FullMeter"
                             Width="240" HorizontalAlignment="Left" Value="100" Margin="0,0,0,20" />

        <TextBlock Text="Labeled, with a custom value formatter" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusMeterLabel x:Name="DiskLabel"
                                  AutomationProperties.AutomationId="DiskLabel"
                                  Text="Disk usage" Margin="0,0,0,4" />
        <navius:NaviusMeter x:Name="LabeledMeter"
                             AutomationProperties.AutomationId="LabeledMeter"
                             Width="240" HorizontalAlignment="Left" Value="65"
                             AutomationProperties.LabeledBy="{Binding ElementName=DiskLabel}"
                             Margin="0,0,0,4" />
        <navius:NaviusMeterValue Source="{Binding ElementName=LabeledMeter}"
                                  AutomationProperties.AutomationId="LabeledMeterValue" />
    </StackPanel>
</UserControl>
