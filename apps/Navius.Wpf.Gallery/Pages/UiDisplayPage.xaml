<UserControl x:Class="Navius.Wpf.Gallery.Pages.UiDisplayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:card="clr-namespace:Navius.Wpf.Ui.Card;assembly=Navius.Wpf.Ui"
             xmlns:alert="clr-namespace:Navius.Wpf.Ui.Alert;assembly=Navius.Wpf.Ui"
             xmlns:badge="clr-namespace:Navius.Wpf.Ui.Badge;assembly=Navius.Wpf.Ui"
             xmlns:skeleton="clr-namespace:Navius.Wpf.Ui.Skeleton;assembly=Navius.Wpf.Ui"
             xmlns:spinner="clr-namespace:Navius.Wpf.Ui.Spinner;assembly=Navius.Wpf.Ui"
             xmlns:kbd="clr-namespace:Navius.Wpf.Ui.Kbd;assembly=Navius.Wpf.Ui"
             xmlns:empty="clr-namespace:Navius.Wpf.Ui.Empty;assembly=Navius.Wpf.Ui"
             xmlns:item="clr-namespace:Navius.Wpf.Ui.Item;assembly=Navius.Wpf.Ui"
             xmlns:timeline="clr-namespace:Navius.Wpf.Ui.Timeline;assembly=Navius.Wpf.Ui"
             AutomationProperties.AutomationId="UiDisplayDemo"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Self-contained: this page merges every item's own dictionary locally rather
                     than relying on Generic.xaml (out of scope here, orchestrator-owned). -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Card.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Alert.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Badge.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Skeleton.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Spinner.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Kbd.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Typography.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Empty.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Item.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Table.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Timeline.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="UI display items" Style="{StaticResource Navius.Typography.H2}" Margin="0,0,0,4" />
            <TextBlock Text="Card, Alert, Badge, Skeleton, Spinner, Kbd, Typography, Empty, Item, Table and Timeline."
                       Style="{StaticResource Navius.Typography.Muted}" Margin="0,0,0,24" TextWrapping="Wrap" />

            <!-- Card -->
            <TextBlock Text="Card" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <card:NaviusCard AutomationProperties.AutomationId="CardDemo" HorizontalAlignment="Left" MaxWidth="360" Margin="0,0,0,24">
                <StackPanel>
                    <card:NaviusCardHeader>
                        <StackPanel>
                            <card:NaviusCardTitle Content="Deployment" />
                            <card:NaviusCardDescription Content="navius-docs, production" />
                        </StackPanel>
                    </card:NaviusCardHeader>
                    <card:NaviusCardContent>
                        <TextBlock Text="Last deployed 12 minutes ago." TextWrapping="Wrap" Foreground="{DynamicResource Navius.CardForeground}" FontSize="13" />
                    </card:NaviusCardContent>
                    <card:NaviusCardFooter>
                        <StackPanel Orientation="Horizontal">
                            <badge:NaviusBadge Variant="Default" Content="Live" />
                            <badge:NaviusBadge Variant="Outline" Content="v0.4.1" />
                        </StackPanel>
                    </card:NaviusCardFooter>
                </StackPanel>
            </card:NaviusCard>

            <!-- Alert -->
            <TextBlock Text="Alert" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <alert:NaviusAlert AutomationProperties.AutomationId="AlertDefault" Variant="Default" Margin="0,0,0,8">
                <StackPanel>
                    <alert:NaviusAlertTitle Content="Heads up" />
                    <alert:NaviusAlertDescription Content="You can add components to your project using the CLI." />
                </StackPanel>
            </alert:NaviusAlert>
            <alert:NaviusAlert AutomationProperties.AutomationId="AlertDestructive" Variant="Destructive" Margin="0,0,0,24">
                <StackPanel>
                    <alert:NaviusAlertTitle Content="Deployment failed" />
                    <alert:NaviusAlertDescription Content="Check the build log for the exact step that failed." />
                </StackPanel>
            </alert:NaviusAlert>

            <!-- Badge -->
            <TextBlock Text="Badge" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <badge:NaviusBadge AutomationProperties.AutomationId="BadgeDefault" Variant="Default" Content="Default" Margin="0,0,8,0" />
                <badge:NaviusBadge AutomationProperties.AutomationId="BadgeSecondary" Variant="Secondary" Content="Secondary" Margin="0,0,8,0" />
                <badge:NaviusBadge AutomationProperties.AutomationId="BadgeOutline" Variant="Outline" Content="Outline" Margin="0,0,8,0" />
                <badge:NaviusBadge AutomationProperties.AutomationId="BadgeDestructive" Variant="Destructive" Content="Destructive" />
            </StackPanel>

            <!-- Skeleton -->
            <TextBlock Text="Skeleton" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <StackPanel Margin="0,0,0,24">
                <skeleton:NaviusSkeleton AutomationProperties.AutomationId="SkeletonTitle" Width="200" Height="16" Margin="0,0,0,8" HorizontalAlignment="Left" />
                <skeleton:NaviusSkeleton Width="320" Height="12" Margin="0,0,0,4" HorizontalAlignment="Left" />
                <skeleton:NaviusSkeleton Width="260" Height="12" HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Spinner -->
            <TextBlock Text="Spinner" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <spinner:NaviusSpinner AutomationProperties.AutomationId="SpinnerDemo" Margin="0,0,8,0" />
                <TextBlock Text="Loading..." Style="{StaticResource Navius.Typography.Muted}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Kbd -->
            <TextBlock Text="Kbd" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24" VerticalAlignment="Center">
                <kbd:NaviusKbdGroup AutomationProperties.AutomationId="KbdGroupDemo">
                    <kbd:NaviusKbd Content="Ctrl" />
                    <kbd:NaviusKbd Content="Shift" />
                    <kbd:NaviusKbd Content="P" />
                </kbd:NaviusKbdGroup>
                <TextBlock Text="Command palette" Style="{StaticResource Navius.Typography.Muted}" Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Typography -->
            <TextBlock Text="Typography" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Heading 1" Style="{StaticResource Navius.Typography.H1}" />
                <TextBlock Text="Heading 2" Style="{StaticResource Navius.Typography.H2}" />
                <TextBlock Text="Heading 3" Style="{StaticResource Navius.Typography.H3}" />
                <TextBlock Text="Heading 4" Style="{StaticResource Navius.Typography.H4}" />
                <TextBlock Text="A lead paragraph draws the eye to the page's opening line." Style="{StaticResource Navius.Typography.Lead}" TextWrapping="Wrap" />
                <TextBlock Text="Muted text for supplementary detail." Style="{StaticResource Navius.Typography.Muted}" />
                <TextBlock Text="dotnet build" Style="{StaticResource Navius.Typography.Code}" HorizontalAlignment="Left" />
                <TextBlock Text="&quot;Simplicity is the ultimate sophistication.&quot;" Style="{StaticResource Navius.Typography.Blockquote}" />
            </StackPanel>

            <!-- Empty -->
            <TextBlock Text="Empty" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <empty:NaviusEmpty AutomationProperties.AutomationId="EmptyDemo" Margin="0,0,0,24">
                <StackPanel>
                    <empty:NaviusEmptyMedia Variant="Icon" Content="?" HorizontalAlignment="Center" />
                    <empty:NaviusEmptyTitle Content="No results" HorizontalAlignment="Center" />
                    <empty:NaviusEmptyDescription Content="Try a different search term." HorizontalAlignment="Center" />
                </StackPanel>
            </empty:NaviusEmpty>

            <!-- Item -->
            <TextBlock Text="Item" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <StackPanel Margin="0,0,0,24">
                <item:NaviusItem AutomationProperties.AutomationId="ItemOne" Variant="Outline" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <item:NaviusItemMedia Variant="Icon" Content="N" />
                        <item:NaviusItemContent>
                            <item:NaviusItemTitle Content="navius-docs" />
                            <item:NaviusItemDescription Content="Documentation site, deployed" />
                        </item:NaviusItemContent>
                        <badge:NaviusBadge Variant="Outline" Content="main" HorizontalAlignment="Right" Margin="12,0,0,0" />
                    </StackPanel>
                </item:NaviusItem>
                <item:NaviusItem AutomationProperties.AutomationId="ItemTwo" Variant="Outline">
                    <StackPanel Orientation="Horizontal">
                        <item:NaviusItemMedia Variant="Icon" Content="Z" />
                        <item:NaviusItemContent>
                            <item:NaviusItemTitle Content="zits-helm" />
                            <item:NaviusItemDescription Content="Component registry, build queued" />
                        </item:NaviusItemContent>
                        <badge:NaviusBadge Variant="Secondary" Content="queued" HorizontalAlignment="Right" Margin="12,0,0,0" />
                    </StackPanel>
                </item:NaviusItem>
            </StackPanel>

            <!-- Table -->
            <TextBlock Text="Table" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <ListView x:Name="TableList"
                      AutomationProperties.AutomationId="TableDemo"
                      Style="{StaticResource Navius.Table}"
                      ItemContainerStyle="{StaticResource Navius.Table.Row}"
                      Margin="0,0,0,24">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource Navius.Table.ColumnHeader}">
                        <GridViewColumn Header="Project" Width="180" DisplayMemberBinding="{Binding Project}" />
                        <GridViewColumn Header="Status" Width="120" DisplayMemberBinding="{Binding Status}" />
                        <GridViewColumn Header="Updated" Width="140" DisplayMemberBinding="{Binding Updated}" />
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Timeline -->
            <TextBlock Text="Timeline" Style="{StaticResource Navius.Typography.H4}" Margin="0,0,0,8" />
            <timeline:NaviusTimeline AutomationProperties.AutomationId="TimelineDemo">
                <timeline:NaviusTimelineItem>
                    <timeline:NaviusTimelineItem.Header>
                        <StackPanel>
                            <timeline:NaviusTimelineDot Variant="Default" />
                            <timeline:NaviusTimelineConnector />
                        </StackPanel>
                    </timeline:NaviusTimelineItem.Header>
                    <timeline:NaviusTimelineContent>
                        <timeline:NaviusTimelineTitle Content="Repository created" />
                        <timeline:NaviusTimelineDescription Content="navius-wpf scaffolded from the sln template." />
                    </timeline:NaviusTimelineContent>
                </timeline:NaviusTimelineItem>
                <timeline:NaviusTimelineItem>
                    <timeline:NaviusTimelineItem.Header>
                        <StackPanel>
                            <timeline:NaviusTimelineDot Variant="Default" />
                            <timeline:NaviusTimelineConnector />
                        </StackPanel>
                    </timeline:NaviusTimelineItem.Header>
                    <timeline:NaviusTimelineContent>
                        <timeline:NaviusTimelineTitle Content="M4 landed" />
                        <timeline:NaviusTimelineDescription Content="Data + dates wave, 14 families." />
                    </timeline:NaviusTimelineContent>
                </timeline:NaviusTimelineItem>
                <timeline:NaviusTimelineItem>
                    <timeline:NaviusTimelineItem.Header>
                        <timeline:NaviusTimelineDot Variant="Outline" />
                    </timeline:NaviusTimelineItem.Header>
                    <timeline:NaviusTimelineContent>
                        <timeline:NaviusTimelineTitle Content="Styled layer in progress" />
                        <timeline:NaviusTimelineDescription Content="Display batch: Card, Alert, Badge and friends." />
                    </timeline:NaviusTimelineContent>
                </timeline:NaviusTimelineItem>
            </timeline:NaviusTimeline>
        </StackPanel>
    </ScrollViewer>
</UserControl>
