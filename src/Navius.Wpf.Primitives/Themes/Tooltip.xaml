<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls">

    <!--
        Not merged into Generic.xaml (out of scope: another family owns that file, see
        Themes/OverlayBackdrop.xaml for the same precedent). Consumers must merge this
        dictionary themselves, e.g. in the hosting page's own Resources:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Tooltip.xaml" />
    -->
    <Style TargetType="{x:Type controls:NaviusTooltip}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusTooltip}">
                    <Grid>
                        <Border x:Name="PART_Trigger" Background="Transparent">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <controls:NaviusAnchoredPopup
                            x:Name="PART_Popup"
                            Anchor="{Binding ElementName=PART_Trigger}"
                            Side="{TemplateBinding Side}"
                            Align="{TemplateBinding Align}"
                            SideOffset="{TemplateBinding SideOffset}"
                            AlignOffset="{TemplateBinding AlignOffset}"
                            IsOpen="{TemplateBinding IsOpen}">
                            <Border
                                x:Name="PART_PopupContent"
                                AutomationProperties.AutomationId="TooltipPopup"
                                Padding="8,4"
                                Background="{DynamicResource Navius.Popover}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Navius.Radius.Small}"
                                Focusable="False"
                                UIElement.IsHitTestVisible="True">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="12"
                                        Direction="270"
                                        Opacity="0.25"
                                        ShadowDepth="2" />
                                </Border.Effect>
                                <ContentPresenter Content="{TemplateBinding TooltipContent}" TextElement.Foreground="{DynamicResource Navius.PopoverForeground}" />
                            </Border>
                        </controls:NaviusAnchoredPopup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
