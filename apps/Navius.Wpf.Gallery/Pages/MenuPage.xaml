<UserControl x:Class="Navius.Wpf.Gallery.Pages.MenuPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             xmlns:menu="clr-namespace:Navius.Wpf.Primitives.Controls.Menus;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use the
                     Menu family merge this dictionary themselves, same as OverlayPage does
                     for OverlayBackdrop.xaml. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Menu.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24" HorizontalAlignment="Left">
        <TextBlock Text="Menu" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />
        <TextBlock Margin="0,0,0,16" MaxWidth="420"
                   Text="A trigger-anchored dropdown menu (NaviusMenuTrigger + NaviusMenuPopup), built on the native Menu/ContextMenu/MenuItem stack: click to open, arrow keys to navigate, type a letter to jump to a matching item, Escape or an outside click to dismiss."
                   Foreground="{DynamicResource Navius.MutedForeground}" TextWrapping="Wrap" />

        <menu:NaviusMenuTrigger Content="Open menu" HorizontalAlignment="Left">
            <menu:NaviusMenuTrigger.Menu>
                <menu:NaviusMenuPopup MinWidth="220">
                    <menu:NaviusMenuItem Header="New Tab" InputGestureText="Ctrl+T" />
                    <menu:NaviusMenuItem Header="New Window" InputGestureText="Ctrl+N" />
                    <menu:NaviusMenuItem Header="Reopen Closed Tab (submenu)">
                        <menu:NaviusMenuItem Header="Last tab" />
                        <menu:NaviusMenuItem Header="Last window" />
                    </menu:NaviusMenuItem>
                    <menu:NaviusMenuItem Header="Disabled item" IsEnabled="False" />

                    <navius:NaviusSeparator Margin="4,4" />

                    <menu:NaviusMenuGroupLabel Content="View" />
                    <menu:NaviusMenuCheckboxItem Header="Show bookmarks bar" Checked="True" />
                    <menu:NaviusMenuCheckboxItem Header="Show full URLs" Checked="False" />
                    <menu:NaviusMenuCheckboxItem Header="Indeterminate example" Checked="{x:Null}" />

                    <navius:NaviusSeparator Margin="4,4" />

                    <menu:NaviusMenuGroupLabel Content="Zoom" />
                    <menu:NaviusMenuRadioItem Header="50%" Value="50" GroupName="zoom" />
                    <menu:NaviusMenuRadioItem Header="100%" Value="100" GroupName="zoom" IsChecked="True" />
                    <menu:NaviusMenuRadioItem Header="150%" Value="150" GroupName="zoom" />
                </menu:NaviusMenuPopup>
            </menu:NaviusMenuTrigger.Menu>
        </menu:NaviusMenuTrigger>
    </StackPanel>
</UserControl>
