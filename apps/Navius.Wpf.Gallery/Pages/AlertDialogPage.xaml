<UserControl x:Class="Navius.Wpf.Gallery.Pages.AlertDialogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             xmlns:overlaySurface="clr-namespace:Navius.Wpf.Primitives.Controls.OverlaySurface;assembly=Navius.Wpf.Primitives"
             xmlns:alertDialog="clr-namespace:Navius.Wpf.Primitives.Controls.AlertDialog;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use
                     NaviusAlertDialog merge this dictionary themselves. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/AlertDialog.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="AlertDialog"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}" />
            <TextBlock Margin="0,4,0,24"
                       MaxWidth="420"
                       Text="Always modal, no outside-click dismissal. Escape still closes it. Initial focus lands on Cancel (the least-destructive action), per the APG recommendation."
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />
            <navius:NaviusButton x:Name="OpenButton"
                                  AutomationProperties.AutomationId="OpenAlertDialogButton"
                                  HorizontalAlignment="Left"
                                  Content="Delete account"
                                  Click="OnOpenClick" />
        </StackPanel>

        <!--
            Contract: NaviusAlertDialog is declared directly inside the NaviusOverlayLayer (see
            NaviusOverlayLayer's class remarks). The Cancel button is marked with the attached
            NaviusAlertDialog.IsCancelButton property so it receives initial focus on open.
        -->
        <overlaySurface:NaviusOverlayLayer x:Name="OverlayLayer">
            <alertDialog:NaviusAlertDialog x:Name="MyAlertDialog"
                                            AutomationProperties.AutomationId="MyAlertDialog"
                                            Title="Delete account?"
                                            Description="This action cannot be undone. This will permanently delete your account and remove your data.">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <navius:NaviusButton AutomationProperties.AutomationId="AlertDialogCancelButton"
                                          alertDialog:NaviusAlertDialog.IsCancelButton="True"
                                          Margin="0,0,8,0"
                                          Content="Cancel"
                                          Command="{x:Static overlaySurface:NaviusOverlaySurfaceBase.CloseCommand}" />
                    <navius:NaviusButton AutomationProperties.AutomationId="AlertDialogActionButton"
                                          Content="Delete"
                                          Command="{x:Static overlaySurface:NaviusOverlaySurfaceBase.CloseCommand}" />
                </StackPanel>
            </alertDialog:NaviusAlertDialog>
        </overlaySurface:NaviusOverlayLayer>
    </Grid>
</UserControl>
