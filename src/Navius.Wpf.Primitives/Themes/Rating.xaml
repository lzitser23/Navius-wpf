<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls">

    <!-- Fixed 24x24 five-point star glyph (see NaviusRating.cs remarks: the contract's ChildContent
         glyph-override is dropped, this is the one fixed star used everywhere). -->
    <PathGeometry x:Key="Navius.Rating.StarGeometry"
                  Figures="M12,2 L15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 Z" />

    <Style TargetType="{x:Type controls:NaviusRatingItem}">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusRatingItem}">
                    <Grid>
                        <!-- Empty outline, always visible underneath the fill. -->
                        <Path
                            Data="{StaticResource Navius.Rating.StarGeometry}"
                            Stretch="Uniform"
                            Stroke="{DynamicResource Navius.MutedForeground}"
                            StrokeThickness="1"
                            Fill="Transparent" />
                        <!-- data-state="full"/"half" -->
                        <Path
                            x:Name="Fill"
                            Data="{StaticResource Navius.Rating.StarGeometry}"
                            Stretch="Uniform"
                            Fill="{DynamicResource Navius.Primary}"
                            Visibility="Collapsed" />
                        <Rectangle
                            x:Name="FocusRing"
                            Stroke="{DynamicResource Navius.Ring}"
                            StrokeThickness="1"
                            StrokeDashArray="1,1"
                            Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="FillState" Value="Full">
                            <Setter TargetName="Fill" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="FillState" Value="Half">
                            <Setter TargetName="Fill" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Fill" Property="Clip">
                                <Setter.Value>
                                    <RectangleGeometry Rect="0,0,12,24" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- data-highlighted -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Fill" Property="Opacity" Value="0.7" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NaviusRating}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusRating}">
                    <StackPanel x:Name="PART_ItemsHost" Orientation="Horizontal" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
