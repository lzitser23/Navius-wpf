<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:spinner="clr-namespace:Navius.Wpf.Ui.Spinner">

    <Style TargetType="{x:Type spinner:NaviusSpinner}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type spinner:NaviusSpinner}">
                    <!-- A ~270 degree arc (large-arc-flag=1) rather than a full ring: the gap is
                         what reads as "spinning" once rotated, matching the lucide Loader2 glyph. -->
                    <Path
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Stretch="Uniform"
                        Stroke="{TemplateBinding Foreground}"
                        StrokeThickness="2"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        Data="M 8,1 A 7,7 0 1 1 1,8"
                        RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinTransform" Angle="0" />
                        </Path.RenderTransform>
                    </Path>
                    <ControlTemplate.Triggers>
                        <!-- Gated on ShouldAnimate: reduced-motion users get a static arc, still
                             legible as "loading" without an endless rotation. -->
                        <Trigger Property="ShouldAnimate" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="SpinStoryboard">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="0" To="360" Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SpinStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
