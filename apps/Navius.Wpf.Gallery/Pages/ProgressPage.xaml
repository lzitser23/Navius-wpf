<UserControl x:Class="Navius.Wpf.Gallery.Pages.ProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Progress.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Progress"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="420"
                   Text="Read-only indicator: determinate, complete, indeterminate, and a labeled example with a custom value formatter."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <TextBlock Text="Progressing (30%)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusProgress AutomationProperties.AutomationId="ProgressingBar"
                                Width="240" HorizontalAlignment="Left" Value="30" Margin="0,0,0,20" />

        <TextBlock Text="Complete" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusProgress AutomationProperties.AutomationId="CompleteBar"
                                Width="240" HorizontalAlignment="Left" Value="100" Margin="0,0,0,20" />

        <TextBlock Text="Indeterminate" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusProgress AutomationProperties.AutomationId="IndeterminateBar"
                                Width="240" HorizontalAlignment="Left" IsIndeterminate="True" Margin="0,0,0,20" />

        <TextBlock Text="Labeled, with a custom value formatter" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusProgressLabel x:Name="DownloadLabel"
                                     AutomationProperties.AutomationId="DownloadLabel"
                                     Text="Download progress" Margin="0,0,0,4" />
        <navius:NaviusProgress x:Name="LabeledProgress"
                                AutomationProperties.AutomationId="LabeledProgress"
                                Width="240" HorizontalAlignment="Left" Value="65"
                                AutomationProperties.LabeledBy="{Binding ElementName=DownloadLabel}"
                                Margin="0,0,0,4" />
        <navius:NaviusProgressValue Source="{Binding ElementName=LabeledProgress}"
                                     AutomationProperties.AutomationId="LabeledProgressValue" />
    </StackPanel>
</UserControl>
