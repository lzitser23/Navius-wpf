<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls">

    <!--
        Not merged into Generic.xaml (out of scope: another family owns that file, see
        Themes/OverlayBackdrop.xaml for the same precedent). Consumers must merge this
        dictionary themselves, e.g. in the hosting page's own Resources:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Popover.xaml" />
    -->
    <Style TargetType="{x:Type controls:NaviusPopover}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusPopover}">
                    <Grid>
                        <Button
                            x:Name="PART_Trigger"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AutomationProperties.AutomationId="PopoverTrigger"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="{TemplateBinding Content}" />

                        <controls:NaviusAnchoredPopup
                            x:Name="PART_Popup"
                            Anchor="{Binding ElementName=PART_Trigger}"
                            Side="{TemplateBinding Side}"
                            Align="{TemplateBinding Align}"
                            SideOffset="{TemplateBinding SideOffset}"
                            AlignOffset="{TemplateBinding AlignOffset}"
                            IsOpen="{TemplateBinding IsOpen}">
                            <Border
                                x:Name="PART_PopupContent"
                                MinWidth="220"
                                Padding="16"
                                AutomationProperties.AutomationId="PopoverPopup"
                                Background="{DynamicResource Navius.Popover}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Navius.Radius.Card}"
                                Focusable="True"
                                FocusVisualStyle="{x:Null}">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="16"
                                        Direction="270"
                                        Opacity="0.3"
                                        ShadowDepth="4" />
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Navius.PopoverForeground}"
                                        Text="{TemplateBinding Title}" />
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Foreground="{DynamicResource Navius.MutedForeground}"
                                        Text="{TemplateBinding Description}"
                                        TextWrapping="Wrap" />
                                    <ContentPresenter Content="{TemplateBinding PopoverContent}" TextElement.Foreground="{DynamicResource Navius.PopoverForeground}" />
                                </StackPanel>
                            </Border>
                        </controls:NaviusAnchoredPopup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
