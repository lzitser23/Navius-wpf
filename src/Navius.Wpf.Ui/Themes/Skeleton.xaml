<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:skeleton="clr-namespace:Navius.Wpf.Ui.Skeleton">

    <Style TargetType="{x:Type skeleton:NaviusSkeleton}">
        <Setter Property="Background" Value="{DynamicResource Navius.Muted}" />
        <Setter Property="MinHeight" Value="16" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type skeleton:NaviusSkeleton}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        Opacity="0.75" />
                    <ControlTemplate.Triggers>
                        <!-- Slow opacity pulse; gated on ShouldAnimate so reduced-motion users get a
                             fixed placeholder instead of an endless loop. -->
                        <Trigger Property="ShouldAnimate" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="PulseStoryboard">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation
                                            Storyboard.TargetName="Root"
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.5" To="1.0" Duration="0:0:1.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
