<UserControl x:Class="Navius.Wpf.Gallery.Pages.PositioningPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource Navius.Background}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Anchored positioning"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}" />
            <TextBlock Text="NaviusAnchoredPopup driven by PlacementMath. Click a button to open its popup on the requested side."
                       Margin="0,4,0,24"
                       Foreground="{DynamicResource Navius.MutedForeground}" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,80">
            <StackPanel Margin="16" HorizontalAlignment="Center">
                <controls:NaviusButton x:Name="TopAnchor" Content="Top" Click="OnToggleTop" />
                <controls:NaviusAnchoredPopup x:Name="TopPopup"
                                               Anchor="{Binding ElementName=TopAnchor}"
                                               Side="Top" Align="Center" SideOffset="8">
                    <Border Background="{DynamicResource Navius.Popover}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Navius.Radius.Small}"
                            Padding="12,8">
                        <TextBlock Text="Placed on top" Foreground="{DynamicResource Navius.PopoverForeground}" />
                    </Border>
                </controls:NaviusAnchoredPopup>
            </StackPanel>

            <StackPanel Margin="16" HorizontalAlignment="Center">
                <controls:NaviusButton x:Name="BottomAnchor" Content="Bottom" Click="OnToggleBottom" />
                <controls:NaviusAnchoredPopup x:Name="BottomPopup"
                                               Anchor="{Binding ElementName=BottomAnchor}"
                                               Side="Bottom" Align="Center" SideOffset="8">
                    <Border Background="{DynamicResource Navius.Popover}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Navius.Radius.Small}"
                            Padding="12,8">
                        <TextBlock Text="Placed on bottom" Foreground="{DynamicResource Navius.PopoverForeground}" />
                    </Border>
                </controls:NaviusAnchoredPopup>
            </StackPanel>

            <StackPanel Margin="16" HorizontalAlignment="Center">
                <controls:NaviusButton x:Name="LeftAnchor" Content="Left" Click="OnToggleLeft" />
                <controls:NaviusAnchoredPopup x:Name="LeftPopup"
                                               Anchor="{Binding ElementName=LeftAnchor}"
                                               Side="Left" Align="Center" SideOffset="8">
                    <Border Background="{DynamicResource Navius.Popover}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Navius.Radius.Small}"
                            Padding="12,8">
                        <TextBlock Text="Placed on left" Foreground="{DynamicResource Navius.PopoverForeground}" />
                    </Border>
                </controls:NaviusAnchoredPopup>
            </StackPanel>

            <StackPanel Margin="16" HorizontalAlignment="Center">
                <controls:NaviusButton x:Name="RightAnchor" Content="Right" Click="OnToggleRight" />
                <controls:NaviusAnchoredPopup x:Name="RightPopup"
                                               Anchor="{Binding ElementName=RightAnchor}"
                                               Side="Right" Align="Center" SideOffset="8">
                    <Border Background="{DynamicResource Navius.Popover}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Navius.Radius.Small}"
                            Padding="12,8">
                        <TextBlock Text="Placed on right" Foreground="{DynamicResource Navius.PopoverForeground}" />
                    </Border>
                </controls:NaviusAnchoredPopup>
            </StackPanel>
        </UniformGrid>

        <StackPanel Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Right">
            <TextBlock Text="Near-edge anchor: requests bottom placement, but tall content flips it to top once the screen runs out of room below."
                       TextWrapping="Wrap"
                       MaxWidth="260"
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       Margin="0,0,0,8" />
            <controls:NaviusButton x:Name="EdgeAnchor" Content="Near bottom edge" HorizontalAlignment="Right" Click="OnToggleEdge" />
            <controls:NaviusAnchoredPopup x:Name="EdgePopup"
                                           Anchor="{Binding ElementName=EdgeAnchor}"
                                           Side="Bottom" Align="End" SideOffset="8">
                <Border Background="{DynamicResource Navius.Popover}"
                        BorderBrush="{DynamicResource Navius.Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        Padding="12,8"
                        Width="220"
                        Height="260">
                    <TextBlock Text="Tall popup content that will not fit below this anchor near the bottom of the screen, so PlacementMath flips it to Top."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Navius.PopoverForeground}" />
                </Border>
            </controls:NaviusAnchoredPopup>
        </StackPanel>
    </Grid>
</UserControl>
