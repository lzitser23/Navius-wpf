<UserControl x:Class="Navius.Wpf.Gallery.Pages.OneTimePasswordFieldPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:otp="clr-namespace:Navius.Wpf.Primitives.Controls.OneTimePasswordField;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/OneTimePasswordField.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="OneTimePasswordField" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Default (6 numeric cells; type / Backspace / Delete / paste)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <otp:NaviusOneTimePasswordField x:Name="DefaultOtp"
                                        AutomationProperties.AutomationId="DefaultOtp"
                                        HorizontalAlignment="Left" Margin="0,0,0,4" />
        <TextBlock x:Name="DefaultOtpValue" Text="Value: (empty)"
                   Foreground="{DynamicResource Navius.MutedForeground}" FontSize="12" Margin="0,0,0,16" />

        <TextBlock Text="4 cells, alphanumeric, AutoSubmit (raises AutoSubmitted when full)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <otp:NaviusOneTimePasswordField x:Name="AutoSubmitOtp"
                                        AutomationProperties.AutomationId="AutoSubmitOtp"
                                        Length="4" ValidationType="alphanumeric" AutoSubmit="True"
                                        HorizontalAlignment="Left" Margin="0,0,0,4" />
        <TextBlock x:Name="AutoSubmitStatus" Text="Waiting for all 4 cells..."
                   Foreground="{DynamicResource Navius.MutedForeground}" FontSize="12" Margin="0,0,0,16" />

        <TextBlock Text="Masked (Type=password)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <otp:NaviusOneTimePasswordField AutomationProperties.AutomationId="MaskedOtp"
                                        Type="password" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Read-only (pre-filled)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <otp:NaviusOneTimePasswordField AutomationProperties.AutomationId="ReadOnlyOtp"
                                        Value="123456" ReadOnly="True" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <otp:NaviusOneTimePasswordField AutomationProperties.AutomationId="DisabledOtp"
                                        Disabled="True" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
