<UserControl x:Class="Navius.Wpf.Gallery.Pages.FormPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:field="clr-namespace:Navius.Wpf.Primitives.Controls.Field;assembly=Navius.Wpf.Primitives"
             xmlns:form="clr-namespace:Navius.Wpf.Primitives.Controls.Form;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges them directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Field.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Form.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24" MaxWidth="420" HorizontalAlignment="Left">
        <TextBlock Text="Form" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Submit gating: submitting reveals all field errors; Submitted fires only when every field is valid. 'Inject server error' simulates Errors-by-name injection."
                   Foreground="{DynamicResource Navius.MutedForeground}" TextWrapping="Wrap" Margin="0,0,0,8" />

        <form:NaviusForm x:Name="DemoForm" AutomationProperties.AutomationId="DemoForm">
            <StackPanel>
                <field:NaviusField x:Name="UsernameField" FieldName="username" Margin="0,0,0,8">
                    <StackPanel>
                        <field:NaviusFieldLabel Content="Username" />
                        <field:NaviusFieldControl />
                        <field:NaviusFieldError />
                    </StackPanel>
                </field:NaviusField>

                <field:NaviusField x:Name="PasswordField" FieldName="password" Invalid="True" Margin="0,0,0,12">
                    <StackPanel>
                        <field:NaviusFieldLabel Content="Password" />
                        <field:NaviusFieldControl />
                        <field:NaviusFieldError Content="Password is required." />
                    </StackPanel>
                </field:NaviusField>

                <StackPanel Orientation="Horizontal">
                    <form:NaviusFormSubmit Content="Submit" AutomationProperties.AutomationId="SubmitButton" />
                    <Button x:Name="InjectErrorButton" Content="Inject server error" Margin="8,0,0,0" />
                    <Button x:Name="FixButton" Content="Mark valid" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </form:NaviusForm>

        <TextBlock x:Name="FormStatus" Text="Not submitted yet."
                   Foreground="{DynamicResource Navius.MutedForeground}" FontSize="12" Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
