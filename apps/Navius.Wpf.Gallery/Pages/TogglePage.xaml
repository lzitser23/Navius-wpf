<UserControl x:Class="Navius.Wpf.Gallery.Pages.TogglePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <StackPanel Margin="24">
        <TextBlock Text="Toggle" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Default" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusToggle Content="Toggle" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Pressed" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusToggle Content="Toggle" IsChecked="True" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusToggle Content="Toggle" IsEnabled="False" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Disabled + pressed" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusToggle Content="Toggle" IsChecked="True" IsEnabled="False" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
