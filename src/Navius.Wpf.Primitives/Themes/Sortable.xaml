<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sortable="clr-namespace:Navius.Wpf.Primitives.Controls.Sortable">

    <!--
        Not merged into Generic.xaml (out of scope for this change: another family owns that file,
        same as Themes/Toast.xaml). Consumers merge this dictionary themselves, e.g. in the hosting
        page's own Resources:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Sortable.xaml" />

        One-ink brand: hairline 1px borders, no shadows.
    -->

    <Style TargetType="{x:Type sortable:NaviusSortable}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sortable:NaviusSortable}">
                    <Border Background="Transparent">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Disabled" Value="True">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type sortable:NaviusSortableItem}">
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.CardForeground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sortable:NaviusSortableItem}">
                    <Border
                        x:Name="Bd"
                        Background="{DynamicResource Navius.Card}"
                        BorderBrush="{DynamicResource Navius.Border}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <!-- data-keyboard-grabbed / aria-grabbed -->
                        <Trigger Property="IsKeyboardGrabbed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Navius.Muted}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <!-- data-dragging -->
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                        </Trigger>
                        <!-- data-drop-target -->
                        <Trigger Property="IsDropTarget" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Navius.Accent}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <Trigger Property="Disabled" Value="True">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sortable:NaviusSortableItemHandle}">
        <Setter Property="Cursor" Value="SizeAll" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sortable:NaviusSortableItemHandle}">
                    <!-- Six-dot grip glyph; two columns of three dots. -->
                    <UniformGrid Rows="3" Columns="2" Width="10" Height="16">
                        <Ellipse Width="3" Height="3" Margin="1" Fill="{TemplateBinding Foreground}" />
                        <Ellipse Width="3" Height="3" Margin="1" Fill="{TemplateBinding Foreground}" />
                        <Ellipse Width="3" Height="3" Margin="1" Fill="{TemplateBinding Foreground}" />
                        <Ellipse Width="3" Height="3" Margin="1" Fill="{TemplateBinding Foreground}" />
                        <Ellipse Width="3" Height="3" Margin="1" Fill="{TemplateBinding Foreground}" />
                        <Ellipse Width="3" Height="3" Margin="1" Fill="{TemplateBinding Foreground}" />
                    </UniformGrid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
