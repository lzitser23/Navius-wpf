<UserControl x:Class="Navius.Wpf.Gallery.Pages.CalendarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cal="clr-namespace:Navius.Wpf.Primitives.Controls.Calendar;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use the
                     Calendar family merge this dictionary themselves, same as SelectPage does
                     for Select.xaml. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Calendar.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24" HorizontalAlignment="Left">
        <TextBlock Text="Calendar" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />
        <TextBlock Margin="0,0,0,16" MaxWidth="420"
                   Text="The calendar surface (NaviusCalendar, Tier A over the native Calendar): arrow keys move by day, PageUp/PageDown by month, Home/End to the week's edges, Enter/Space selects, and the header button zooms out to year and decade views. The second instance runs the native SingleRange surface."
                   Foreground="{DynamicResource Navius.MutedForeground}" TextWrapping="Wrap" />

        <TextBlock Text="Single date" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <cal:NaviusCalendar
            AutomationProperties.AutomationId="CalendarDemo"
            HorizontalAlignment="Left"
            Margin="0,0,0,20" />

        <TextBlock Text="Range surface (SingleRange)" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <cal:NaviusCalendar
            SelectionMode="SingleRange"
            HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
