<UserControl x:Class="Navius.Wpf.Gallery.Pages.FieldPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:field="clr-namespace:Navius.Wpf.Primitives.Controls.Field;assembly=Navius.Wpf.Primitives"
             xmlns:fieldset="clr-namespace:Navius.Wpf.Primitives.Controls.Fieldset;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges them directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Field.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Fieldset.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24" MaxWidth="420" HorizontalAlignment="Left">
        <TextBlock Text="Field + Fieldset" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Basic field (label + default input + description)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <field:NaviusField FieldName="name" AutomationProperties.AutomationId="BasicField" Margin="0,0,0,16">
            <StackPanel>
                <field:NaviusFieldLabel Content="Name" />
                <field:NaviusFieldControl />
                <field:NaviusFieldDescription Content="Visible on your profile." />
            </StackPanel>
        </field:NaviusField>

        <TextBlock Text="Invalid field, revealed on demand (ValidationMode=OnSubmit)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <field:NaviusField x:Name="InvalidField" FieldName="email" Invalid="True"
                           AutomationProperties.AutomationId="InvalidField" Margin="0,0,0,4">
            <StackPanel>
                <field:NaviusFieldLabel Content="Email" />
                <field:NaviusFieldControl />
                <field:NaviusFieldError Content="Enter a valid email address." />
            </StackPanel>
        </field:NaviusField>
        <Button x:Name="RevealButton" Content="Reveal validity" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="ValidationMode=OnChange (error appears as you type)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <field:NaviusField FieldName="username" Invalid="True" ValidationMode="OnChange"
                           AutomationProperties.AutomationId="OnChangeField" Margin="0,0,0,16">
            <StackPanel>
                <field:NaviusFieldLabel Content="Username" />
                <field:NaviusFieldControl />
                <field:NaviusFieldError Content="This username is taken." />
            </StackPanel>
        </field:NaviusField>

        <TextBlock Text="Fieldset (legend + disabled cascade)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <fieldset:NaviusFieldset Disabled="True" AutomationProperties.AutomationId="DisabledFieldset">
            <StackPanel>
                <fieldset:NaviusFieldsetLegend Content="Shipping address" />
                <field:NaviusField FieldName="street" Margin="0,0,0,8">
                    <StackPanel>
                        <field:NaviusFieldLabel Content="Street" />
                        <field:NaviusFieldControl />
                    </StackPanel>
                </field:NaviusField>
                <field:NaviusField FieldName="city">
                    <StackPanel>
                        <field:NaviusFieldLabel Content="City" />
                        <field:NaviusFieldControl />
                    </StackPanel>
                </field:NaviusField>
            </StackPanel>
        </fieldset:NaviusFieldset>
    </StackPanel>
</UserControl>
