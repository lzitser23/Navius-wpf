<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls">

    <Style TargetType="{x:Type controls:NaviusNumberField}">
        <Setter Property="Background" Value="{DynamicResource Navius.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Input}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusNumberField}">
                    <!-- Group: a plain role="group" wrapper in the contract, no behavior of its
                         own; folded into this Border rather than a separate CLR type (see
                         NaviusNumberField.cs remarks). -->
                    <Border
                        x:Name="Group"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="PART_Input"
                                Grid.Column="0"
                                Padding="8,6"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="{TemplateBinding Foreground}"
                                VerticalContentAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                <RepeatButton
                                    x:Name="PART_Increment"
                                    Content="+"
                                    Width="20" Height="16"
                                    Padding="0"
                                    Focusable="False"
                                    AutomationProperties.Name="Increase" />
                                <RepeatButton
                                    x:Name="PART_Decrement"
                                    Content="-"
                                    Width="20" Height="16"
                                    Padding="0"
                                    Focusable="False"
                                    AutomationProperties.Name="Decrease" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Group" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <Trigger Property="CanIncrement" Value="False">
                            <Setter TargetName="PART_Increment" Property="IsEnabled" Value="False" />
                        </Trigger>
                        <Trigger Property="CanDecrement" Value="False">
                            <Setter TargetName="PART_Decrement" Property="IsEnabled" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
