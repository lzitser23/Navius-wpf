<UserControl x:Class="Navius.Wpf.Gallery.Pages.AutocompletePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use
                     NaviusAutocomplete merge this dictionary themselves, same precedent as
                     PopoverPage does for Popover.xaml. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Autocomplete.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Autocomplete"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="440"
                   Text="Type to filter. ArrowDown/ArrowUp move the highlight (a data pointer, not focus, which never leaves the text box), Enter commits the highlighted row, Home/End jump to first/last, Escape or an outside click dismiss. Click a row to select it."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <!-- NaviusAutocomplete<TItem> is generic; it is constructed in code-behind and hosted here
             (avoids the fragility of x:TypeArguments in classic WPF XAML). -->
        <ContentControl x:Name="Host" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
