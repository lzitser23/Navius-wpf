<UserControl x:Class="Navius.Wpf.Gallery.Pages.DatePickerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dp="clr-namespace:Navius.Wpf.Primitives.Controls.DatePicker;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use the
                     DatePicker family merge this dictionary themselves (it merges
                     Calendar.xaml transitively), same as SelectPage does for Select.xaml. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/DatePicker.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24" HorizontalAlignment="Left">
        <TextBlock Text="DatePicker" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />
        <TextBlock Margin="0,0,0,16" MaxWidth="420"
                   Text="A calendar-popup date picker (NaviusDatePicker): click or press Enter/Space/ArrowDown to open, arrow keys navigate days without committing, Enter or a day click commits and closes, Escape or an outside click dismisses. The trigger text is a read-only display; segmented editing belongs to the DateInput family."
                   Foreground="{DynamicResource Navius.MutedForeground}" TextWrapping="Wrap" />

        <TextBlock Text="Single date" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <dp:NaviusDatePicker
            AutomationProperties.AutomationId="DatePickerDemo"
            Placeholder="Pick a date"
            HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
