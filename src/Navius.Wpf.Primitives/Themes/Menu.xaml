<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:menu="clr-namespace:Navius.Wpf.Primitives.Controls.Menus">

    <!-- NaviusMenuTrigger: toggle-button chrome; IsChecked reflects data-popup-open. -->
    <Style TargetType="{x:Type menu:NaviusMenuTrigger}">
        <Setter Property="Background" Value="{DynamicResource Navius.Secondary}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.SecondaryForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menu:NaviusMenuTrigger}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <!-- data-popup-open -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Navius.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Navius.AccentForeground}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenuPopup: the menu surface. ContextMenu already owns its own floating Popup;
         this template only supplies the popover-surface chrome for its content root. -->
    <Style TargetType="{x:Type menu:NaviusMenuPopup}">
        <Setter Property="Background" Value="{DynamicResource Navius.Popover}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menu:NaviusMenuPopup}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        Padding="{TemplateBinding Padding}">
                        <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter Grid.IsSharedSizeScope="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenuItem: leaf activation row, plus the native submenu Popup chrome (PART_Popup)
         used only when Role == SubmenuHeader (this item has children). -->
    <Style TargetType="{x:Type menu:NaviusMenuItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menu:NaviusMenuItem}">
                    <Border
                        x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="NaviusMenuItemIcon" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="NaviusMenuItemGesture" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="NaviusMenuItemArrow" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter
                                x:Name="Icon"
                                Grid.Column="0"
                                ContentSource="Icon"
                                Width="16" Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center" />

                            <ContentPresenter
                                Grid.Column="1"
                                ContentSource="Header"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />

                            <TextBlock
                                Grid.Column="2"
                                Text="{TemplateBinding InputGestureText}"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Navius.MutedForeground}" />

                            <Path
                                x:Name="SubmenuArrow"
                                Grid.Column="3"
                                Data="M 0,0 L 4,4 L 0,8"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Stroke="{TemplateBinding Foreground}"
                                StrokeThickness="1.4"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round"
                                StrokeLineJoin="Round"
                                Visibility="Collapsed" />

                            <Popup
                                x:Name="PART_Popup"
                                Placement="Right"
                                PlacementTarget="{Binding ElementName=Bd}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="None">
                                <Border
                                    Background="{DynamicResource Navius.Popover}"
                                    BorderBrush="{DynamicResource Navius.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource Navius.Radius.Control}"
                                    Padding="4">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter Grid.IsSharedSizeScope="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- data-highlighted -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Navius.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Navius.AccentForeground}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenuCheckboxItem: leaf row with a check/dash glyph column; never has children. -->
    <Style TargetType="{x:Type menu:NaviusMenuCheckboxItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menu:NaviusMenuCheckboxItem}">
                    <Border
                        x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <!-- data-checked -->
                                <Path
                                    x:Name="CheckGlyph"
                                    Data="M 1,5 L 4,8 L 9,1"
                                    Stroke="{TemplateBinding Foreground}"
                                    StrokeThickness="1.6"
                                    StrokeStartLineCap="Round"
                                    StrokeEndLineCap="Round"
                                    StrokeLineJoin="Round"
                                    Visibility="Collapsed" />
                                <!-- data-indeterminate -->
                                <Rectangle
                                    x:Name="IndeterminateGlyph"
                                    Width="8" Height="1.6"
                                    Fill="{TemplateBinding Foreground}"
                                    Visibility="Collapsed" />
                            </Grid>

                            <ContentPresenter
                                Grid.Column="1"
                                ContentSource="Header"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="IndeterminateGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- data-highlighted -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Navius.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Navius.AccentForeground}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenuRadioItem: leaf row with a dot glyph column; never has children. -->
    <Style TargetType="{x:Type menu:NaviusMenuRadioItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menu:NaviusMenuRadioItem}">
                    <Border
                        x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- data-checked -->
                            <Ellipse
                                x:Name="Dot"
                                Grid.Column="0"
                                Width="6" Height="6"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Fill="{TemplateBinding Foreground}"
                                Visibility="Collapsed" />

                            <ContentPresenter
                                Grid.Column="1"
                                ContentSource="Header"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- data-highlighted -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Navius.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Navius.AccentForeground}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenuGroupLabel: muted, non-interactive heading. -->
    <Style TargetType="{x:Type menu:NaviusMenuGroupLabel}">
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menu:NaviusMenuGroupLabel}">
                    <ContentPresenter
                        Margin="{TemplateBinding Padding}"
                        TextElement.FontSize="11"
                        TextElement.FontWeight="SemiBold"
                        TextElement.Foreground="{DynamicResource Navius.MutedForeground}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
