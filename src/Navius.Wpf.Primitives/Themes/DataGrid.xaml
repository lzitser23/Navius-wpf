<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dg="clr-namespace:Navius.Wpf.Primitives.Controls.DataGrid">

    <!--
        Not merged into Generic.xaml (out of scope: another family owns that file, same precedent as
        Meter.xaml/Rating.xaml). Consumers merge this dictionary directly, exactly as the gallery
        page does.

        Re-template strategy (see docs/parity/data-grid.md "WPF implementation notes"): the native
        DataGrid's structural ControlTemplate is left intact. The Navius look is applied through
        ColumnHeaderStyle, RowStyle, CellStyle, RowHeaderStyle, and grid-level Setters only. This is
        the low-risk, idiomatic way to reskin System.Windows.Controls.DataGrid without fighting its
        complex default template. One-ink brand: hairline borders, no gridline chrome, no shadows.
    -->

    <!-- Column header: Muted fill, Foreground text, bottom hairline only, re-styled sort glyph. -->
    <Style x:Key="Navius.DataGrid.ColumnHeader" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Background" Value="{DynamicResource Navius.Muted}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            <!-- Downward triangle (Descending). Flipped vertically for Ascending. -->
                            <Path x:Name="SortGlyph" Grid.Column="1"
                                  Width="8" Height="6" Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource Navius.MutedForeground}"
                                  Visibility="Collapsed"
                                  Data="M 0 0 L 8 0 L 4 5 Z" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortGlyph" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortGlyph" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            <Setter TargetName="SortGlyph" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleY="-1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Cell: consistent padding, transparent (so the row paints the full-row selection accent),
         AccentForeground text when the owning row is selected. -->
    <Style x:Key="Navius.DataGrid.Cell" TargetType="{x:Type DataGridCell}">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger
                Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}"
                Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Navius.AccentForeground}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Row: Card surface, hairline bottom separator, full-row Accent fill on selection. -->
    <Style x:Key="Navius.DataGrid.Row" TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{DynamicResource Navius.Card}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRow}">
                    <Border x:Name="RowBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="0,0,0,1"
                            SnapsToDevicePixels="True">
                        <DataGridCellsPresenter
                            ItemsPanel="{TemplateBinding ItemsPanel}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBorder" Property="Background"
                                    Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Row header gutter: hidden (HeadersVisibility=Column already suppresses it; belt-and-suspenders). -->
    <Style x:Key="Navius.DataGrid.RowHeader" TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="Visibility" Value="Collapsed" />
    </Style>

    <Style TargetType="{x:Type dg:NaviusDataGrid}">
        <Setter Property="Background" Value="{DynamicResource Navius.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{DynamicResource Navius.Card}" />
        <Setter Property="FontSize" Value="13" />
        <!-- GridLinesVisibility=None already suppresses gridlines; force the brushes transparent too. -->
        <Setter Property="HorizontalGridLinesBrush" Value="Transparent" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource Navius.DataGrid.ColumnHeader}" />
        <Setter Property="CellStyle" Value="{StaticResource Navius.DataGrid.Cell}" />
        <Setter Property="RowStyle" Value="{StaticResource Navius.DataGrid.Row}" />
        <Setter Property="RowHeaderStyle" Value="{StaticResource Navius.DataGrid.RowHeader}" />
        <!-- Belt-and-suspenders virtualization: keep recycling on even if a future style edit lands. -->
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

</ResourceDictionary>
