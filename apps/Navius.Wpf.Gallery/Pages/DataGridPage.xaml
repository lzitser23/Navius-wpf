<UserControl x:Class="Navius.Wpf.Gallery.Pages.DataGridPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dg="clr-namespace:Navius.Wpf.Primitives.Controls.DataGrid;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/DataGrid.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top" MaxWidth="720">
            <TextBlock Text="DataGrid"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}" />
            <TextBlock Margin="0,4,0,24"
                       Text="A re-templated native DataGrid: global filter, single-column sort, and native row/column virtualization. Selection is set-based (Extended)."
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />

            <!-- Global filter wired straight to NaviusDataGrid.GlobalFilter. -->
            <TextBox x:Name="FilterBox"
                     AutomationProperties.AutomationId="DataGridFilter"
                     Width="260" HorizontalAlignment="Left"
                     Padding="8,6" Margin="0,0,0,12"
                     BorderBrush="{DynamicResource Navius.Input}"
                     Background="{DynamicResource Navius.Card}"
                     Foreground="{DynamicResource Navius.Foreground}" />

            <dg:NaviusDataGrid x:Name="DemoGrid"
                               AutomationProperties.AutomationId="DataGridDemo"
                               GlobalFilter="{Binding Text, ElementName=FilterBox, UpdateSourceTrigger=PropertyChanged}"
                               MaxHeight="240"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,0,32">
                <dg:NaviusDataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" CanUserSort="True" />
                    <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="Auto" CanUserSort="True" />
                    <DataGridTextColumn Header="City" Binding="{Binding City}" Width="Auto" CanUserSort="True" />
                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="2*" CanUserSort="False" />
                </dg:NaviusDataGrid.Columns>
            </dg:NaviusDataGrid>

            <TextBlock Text="10,000 rows (virtualization gate)"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}"
                       Margin="0,0,0,4" />
            <TextBlock Margin="0,0,0,12"
                       Text="The perf-gate demo the milestone measures against. Real NaviusDataGrid, virtualization on: only the visible rows are realized."
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />

            <dg:NaviusDataGrid x:Name="BigGrid"
                               AutomationProperties.AutomationId="DataGrid10kDemo"
                               MaxHeight="320"
                               HorizontalAlignment="Stretch">
                <dg:NaviusDataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto" CanUserSort="True" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" CanUserSort="True" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value, StringFormat=N2}" Width="Auto" CanUserSort="True" />
                </dg:NaviusDataGrid.Columns>
            </dg:NaviusDataGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
