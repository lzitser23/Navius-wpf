<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls">

    <Style TargetType="{x:Type controls:NaviusProgress}">
        <Setter Property="Height" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Navius.Secondary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusProgress}">
                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        ClipToBounds="True">
                        <!-- PART_Track/PART_Indicator are ProgressBar's own required part names; the
                             native base class sizes PART_Indicator's Width from Value/Minimum/Maximum. -->
                        <Grid x:Name="PART_Track">
                            <Rectangle
                                x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                Fill="{TemplateBinding Foreground}" />
                            <Rectangle
                                x:Name="IndeterminatePulse"
                                Fill="{TemplateBinding Foreground}"
                                Opacity="0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="PulseStoryboard">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation
                                            Storyboard.TargetName="IndeterminatePulse"
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.25" To="0.65" Duration="0:0:0.9" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NaviusProgressLabel}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="{x:Type controls:NaviusProgressValue}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

</ResourceDictionary>
