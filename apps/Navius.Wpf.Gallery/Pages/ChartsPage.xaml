<UserControl x:Class="Navius.Wpf.Gallery.Pages.ChartsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:charts="clr-namespace:Navius.Wpf.Charts;assembly=Navius.Wpf.Charts"
             Background="{DynamicResource Navius.Background}">
    <!--
      NOTE (pending wire-up): apps/Navius.Wpf.Gallery/Navius.Wpf.Gallery.csproj does not yet
      reference src/Navius.Wpf.Charts/Navius.Wpf.Charts.csproj, and this page is not wired into
      gallery navigation. Both are expected to happen once the orchestrator adds the project
      reference; this page was verified by building Navius.Wpf.Charts and its tests standalone.
    -->
    <ScrollViewer Padding="32">
        <StackPanel AutomationProperties.AutomationId="ChartsDemo"
                    HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="Charts"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}" />
            <TextBlock Margin="0,4,0,24"
                       MaxWidth="480"
                       Text="A thin, token-themed wrapper over LiveCharts2 (see docs/adr/0004-chart-library.md): line, bar and pie, colored from the current Navius tokens. Negative bar values pick up the destructive color."
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />

            <TextBlock Text="Line" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <charts:NaviusChart x:Name="LineDemo"
                                 AutomationProperties.AutomationId="ChartsLineDemo"
                                 Kind="Line" Width="420" Height="220"
                                 HorizontalAlignment="Left" Margin="0,0,0,24" />

            <TextBlock Text="Bar" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <charts:NaviusChart x:Name="BarDemo"
                                 AutomationProperties.AutomationId="ChartsBarDemo"
                                 Kind="Bar" Width="420" Height="220"
                                 HorizontalAlignment="Left" Margin="0,0,0,24" />

            <TextBlock Text="Pie" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <charts:NaviusChart x:Name="PieDemo"
                                 AutomationProperties.AutomationId="ChartsPieDemo"
                                 Kind="Pie" Width="220" Height="220"
                                 HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
