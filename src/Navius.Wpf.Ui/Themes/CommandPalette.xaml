<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:commandPalette="clr-namespace:Navius.Wpf.Ui.CommandPalette"
    xmlns:overlays="clr-namespace:Navius.Wpf.Primitives.Overlays;assembly=Navius.Wpf.Primitives">

    <!--
        Not merged into Generic.xaml (the orchestrator owns that file). Consumers merge this
        dictionary themselves. This also pulls in Navius.Wpf.Primitives' Themes/OverlayBackdrop.xaml
        for the scrim, same precedent as that assembly's own Themes/Dialog.xaml:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/CommandPalette.xaml" />
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/OverlayBackdrop.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="Navius.CommandPalette.RowTemplate" DataType="{x:Type commandPalette:CommandPaletteRow}">
        <StackPanel>
            <TextBlock
                Margin="10,10,10,4"
                Text="{Binding Item.Group}"
                FontSize="11" FontWeight="SemiBold"
                Foreground="{DynamicResource Navius.MutedForeground}"
                Visibility="{Binding ShowGroupHeader, Converter={x:Static commandPalette:BoolToVisibilityConverter.Instance}}" />
            <Border x:Name="Row" Margin="4,1" Padding="10,8" CornerRadius="{DynamicResource Navius.Radius.Small}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0" Width="18" Height="18" Margin="0,0,10,0" Content="{Binding Item.Icon}" />
                    <TextBlock Grid.Column="1" Text="{Binding Item.Label}" Foreground="{DynamicResource Navius.PopoverForeground}" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style TargetType="{x:Type commandPalette:NaviusCommandPalette}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type commandPalette:NaviusCommandPalette}">
                    <Grid>
                        <overlays:OverlayBackdrop />
                        <Border
                            Width="520"
                            MaxHeight="420"
                            Margin="0,120,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="{DynamicResource Navius.Popover}"
                            BorderBrush="{DynamicResource Navius.Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Navius.Radius.Card}">
                            <DockPanel LastChildFill="True">
                                <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource Navius.Border}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBox
                                            x:Name="PART_Input"
                                            Padding="14,12"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CaretBrush="{DynamicResource Navius.Foreground}"
                                            FontSize="15"
                                            Foreground="{DynamicResource Navius.Foreground}"
                                            Text="{Binding Query, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            Foreground="{DynamicResource Navius.MutedForeground}"
                                            IsHitTestVisible="False"
                                            Text="{TemplateBinding Placeholder}"
                                            Visibility="{Binding Query, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static commandPalette:EmptyStringToVisibilityConverter.Instance}}" />
                                    </Grid>
                                </Border>

                                <TextBlock
                                    DockPanel.Dock="Top"
                                    Margin="14,24"
                                    HorizontalAlignment="Center"
                                    Foreground="{DynamicResource Navius.MutedForeground}"
                                    Text="No matching commands"
                                    Visibility="{TemplateBinding IsEmpty, Converter={x:Static commandPalette:BoolToVisibilityConverter.Instance}}" />

                                <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl
                                        x:Name="PART_List"
                                        Margin="0,4"
                                        Focusable="False"
                                        ItemTemplate="{StaticResource Navius.CommandPalette.RowTemplate}"
                                        ItemsSource="{TemplateBinding FilteredRows}"
                                        KeyboardNavigation.TabNavigation="None" />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
