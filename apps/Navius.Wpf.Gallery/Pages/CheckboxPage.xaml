<UserControl x:Class="Navius.Wpf.Gallery.Pages.CheckboxPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:checkbox="clr-namespace:Navius.Wpf.Primitives.Controls.Checkbox;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <StackPanel Margin="24">
        <TextBlock Text="Checkbox" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <checkbox:NaviusCheckbox Content="Unchecked" Margin="0,0,0,8" />
        <checkbox:NaviusCheckbox Content="Checked" IsChecked="True" Margin="0,0,0,8" />
        <checkbox:NaviusCheckbox Content="Indeterminate" IsChecked="{x:Null}" Margin="0,0,0,8" />
        <checkbox:NaviusCheckbox Content="Disabled" IsEnabled="False" Margin="0,0,0,8" />
        <checkbox:NaviusCheckbox Content="Disabled + checked" IsChecked="True" IsEnabled="False" Margin="0,0,0,8" />
        <checkbox:NaviusCheckbox Content="Read-only, checked" ReadOnly="True" IsChecked="True" Margin="0,0,0,16" />

        <TextBlock Text="Group with select-all roll-up" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <checkbox:NaviusCheckboxGroup x:Name="GroupRoot">
            <StackPanel>
                <checkbox:NaviusCheckbox IsSelectAll="True" Content="Select all" Margin="0,0,0,4" />
                <checkbox:NaviusCheckbox GroupValue="a" Content="Item A" Margin="16,0,0,4" />
                <checkbox:NaviusCheckbox GroupValue="b" Content="Item B" Margin="16,0,0,4" />
                <checkbox:NaviusCheckbox GroupValue="c" Content="Item C" Margin="16,0,0,0" />
            </StackPanel>
        </checkbox:NaviusCheckboxGroup>
    </StackPanel>
</UserControl>
