<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls.RadioGroup">

    <Style TargetType="{x:Type controls:NaviusRadioGroupIndicator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusRadioGroupIndicator}">
                    <Ellipse
                        Width="8" Height="8"
                        Fill="{TemplateBinding Foreground}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NaviusRadioGroupItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusRadioGroupItem}">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Circle"
                                Width="16" Height="16"
                                Background="{DynamicResource Navius.Background}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <controls:NaviusRadioGroupIndicator
                                IsChecked="{TemplateBinding IsChecked}"
                                Foreground="{DynamicResource Navius.PrimaryForeground}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ContentPresenter
                            Margin="8,0,0,0"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <!-- data-checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Circle" Property="Background" Value="{DynamicResource Navius.Primary}" />
                            <Setter TargetName="Circle" Property="BorderBrush" Value="{DynamicResource Navius.Primary}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Circle" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NaviusRadioGroup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusRadioGroup}">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
