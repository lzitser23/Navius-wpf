<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:kbd="clr-namespace:Navius.Wpf.Ui.Kbd">

    <Style TargetType="{x:Type kbd:NaviusKbd}">
        <Setter Property="Background" Value="{DynamicResource Navius.Muted}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="MinWidth" Value="20" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <!-- Gap between consecutive keys inside a NaviusKbdGroup; harmless on a standalone Kbd. -->
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type kbd:NaviusKbd}">
                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource Navius.Radius.Small}"
                        Padding="{TemplateBinding Padding}"
                        MinWidth="{TemplateBinding MinWidth}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type kbd:NaviusKbdGroup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type kbd:NaviusKbdGroup}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
