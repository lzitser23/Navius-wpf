<UserControl x:Class="Navius.Wpf.Gallery.Pages.RtlPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             xmlns:dateInput="clr-namespace:Navius.Wpf.Primitives.Controls.DateInput;assembly=Navius.Wpf.Primitives"
             xmlns:tabs="clr-namespace:Navius.Wpf.Primitives.Controls.Tabs;assembly=Navius.Wpf.Primitives"
             xmlns:breadcrumb="clr-namespace:Navius.Wpf.Ui.Breadcrumb;assembly=Navius.Wpf.Ui"
             Background="{DynamicResource Navius.Background}">
    <!--
        Self-contained manual-inspection page for the M6 RTL wave: not wired into MainWindow's
        navigation (see docs/adr/0006-rtl-dpi-hardening.md). Merges each family's own theme
        directly, same "not merged into Generic.xaml" precedent as SliderPage/ProgressPage/etc.
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Slider.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Progress.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Rating.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/DateInput.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Tabs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Breadcrumb.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer Padding="24">
        <StackPanel AutomationProperties.AutomationId="RtlDemo" FlowDirection="RightToLeft" MaxWidth="480">
            <TextBlock Text="RTL manual inspection" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,4" FlowDirection="LeftToRight" />
            <TextBlock Text="Every control below is inside a FlowDirection=RightToLeft panel."
                       Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,20"
                       TextWrapping="Wrap" FlowDirection="LeftToRight" />

            <TextBlock Text="Slider" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <navius:NaviusSlider AutomationProperties.AutomationId="RtlSlider"
                                  Width="240" HorizontalAlignment="Left"
                                  Minimum="0" Maximum="100" Value="40" Margin="0,0,0,20" />

            <TextBlock Text="Progress (60%)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <navius:NaviusProgress AutomationProperties.AutomationId="RtlProgress"
                                    Width="240" HorizontalAlignment="Left" Value="60" Margin="0,0,0,20" />

            <TextBlock Text="Rating, half-steps (3.5 of 5)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <navius:NaviusRating AutomationProperties.AutomationId="RtlRating"
                                  HorizontalAlignment="Left" AllowHalf="True" Value="3.5" Margin="0,0,0,20" />

            <TextBlock Text="Date input (segment order stays fixed, not mirrored)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <dateInput:NaviusDateInput AutomationProperties.AutomationId="RtlDateInput"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,20" />

            <TextBlock Text="Tabs" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <tabs:NaviusTabs AutomationProperties.AutomationId="RtlTabs" Value="account" Margin="0,0,0,20">
                <tabs:NaviusTabItem Value="account" Header="Account">
                    <TextBlock Text="Account settings go here." Margin="12" Foreground="{DynamicResource Navius.Foreground}" />
                </tabs:NaviusTabItem>
                <tabs:NaviusTabItem Value="password" Header="Password">
                    <TextBlock Text="Password settings go here." Margin="12" Foreground="{DynamicResource Navius.Foreground}" />
                </tabs:NaviusTabItem>
            </tabs:NaviusTabs>

            <TextBlock Text="Breadcrumb (should mirror, unlike DateInput's segments)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
            <breadcrumb:NaviusBreadcrumb AutomationProperties.AutomationId="RtlBreadcrumb" HorizontalAlignment="Left">
                <breadcrumb:NaviusBreadcrumbItem>Home</breadcrumb:NaviusBreadcrumbItem>
                <breadcrumb:NaviusBreadcrumbSeparator />
                <breadcrumb:NaviusBreadcrumbItem>Section</breadcrumb:NaviusBreadcrumbItem>
                <breadcrumb:NaviusBreadcrumbSeparator />
                <breadcrumb:NaviusBreadcrumbItem IsCurrentPage="True">Page</breadcrumb:NaviusBreadcrumbItem>
            </breadcrumb:NaviusBreadcrumb>
        </StackPanel>
    </ScrollViewer>
</UserControl>
