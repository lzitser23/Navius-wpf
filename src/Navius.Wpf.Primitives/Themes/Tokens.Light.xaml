<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Navius brand tokens, light. Values mirror navius-docs Styles/app.css. -->
    <sys:String x:Key="Navius.Tokens.Theme">Light</sys:String>

    <SolidColorBrush x:Key="Navius.Background" Color="#F4F3F0" />
    <SolidColorBrush x:Key="Navius.Foreground" Color="#171614" />
    <SolidColorBrush x:Key="Navius.Card" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Navius.CardForeground" Color="#171614" />
    <SolidColorBrush x:Key="Navius.Popover" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Navius.PopoverForeground" Color="#171614" />
    <SolidColorBrush x:Key="Navius.Primary" Color="#171614" />
    <SolidColorBrush x:Key="Navius.PrimaryForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Navius.Secondary" Color="#E3E3E2" />
    <SolidColorBrush x:Key="Navius.SecondaryForeground" Color="#171614" />
    <SolidColorBrush x:Key="Navius.Muted" Color="#F1F1F0" />
    <SolidColorBrush x:Key="Navius.MutedForeground" Color="#737270" />
    <SolidColorBrush x:Key="Navius.Accent" Color="#F1F1F0" />
    <SolidColorBrush x:Key="Navius.AccentForeground" Color="#171614" />
    <!-- web token is oklch(0.577 0.245 27.325); sRGB equivalent -->
    <SolidColorBrush x:Key="Navius.Destructive" Color="#E7000B" />
    <SolidColorBrush x:Key="Navius.DestructiveForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Navius.Border" Color="#E6E4DE" />
    <SolidColorBrush x:Key="Navius.Input" Color="#D1D0D0" />
    <SolidColorBrush x:Key="Navius.Ring" Color="#171614" />

    <CornerRadius x:Key="Navius.Radius.Small">4</CornerRadius>
    <CornerRadius x:Key="Navius.Radius.Control">6</CornerRadius>
    <CornerRadius x:Key="Navius.Radius.Card">8</CornerRadius>

</ResourceDictionary>
