<UserControl x:Class="Navius.Wpf.Gallery.Pages.DialogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             xmlns:overlaySurface="clr-namespace:Navius.Wpf.Primitives.Controls.OverlaySurface;assembly=Navius.Wpf.Primitives"
             xmlns:dialog="clr-namespace:Navius.Wpf.Primitives.Controls.Dialog;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use NaviusDialog
                     merge this dictionary themselves. It in turn merges OverlayBackdrop.xaml. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Dialog.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="Dialog"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}" />
            <TextBlock Margin="0,4,0,24"
                       MaxWidth="420"
                       Text="Modal by default: focus is trapped inside, Escape and an outside click both dismiss it, and focus returns to this button on close. Title/Description drive the popup's accessible name and help text."
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />
            <navius:NaviusButton x:Name="OpenButton"
                                  AutomationProperties.AutomationId="OpenDialogButton"
                                  HorizontalAlignment="Left"
                                  Content="Open dialog"
                                  Click="OnOpenClick" />
        </StackPanel>

        <!--
            Contract: NaviusDialog is declared directly inside the NaviusOverlayLayer (see
            NaviusOverlayLayer's class remarks) rather than moved there at runtime. It starts
            Collapsed and only becomes visible while IsOpen.
        -->
        <overlaySurface:NaviusOverlayLayer x:Name="OverlayLayer">
            <dialog:NaviusDialog x:Name="MyDialog"
                                  AutomationProperties.AutomationId="MyDialog"
                                  Title="Edit profile"
                                  Description="Update your name and email, then save or close.">
                <StackPanel>
                    <TextBox x:Name="NameInput"
                             AutomationProperties.AutomationId="DialogNameInput"
                             Margin="0,0,0,8"
                             Text="Name" />
                    <TextBox x:Name="EmailInput"
                             AutomationProperties.AutomationId="DialogEmailInput"
                             Margin="0,0,0,16"
                             Text="Email" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <navius:NaviusButton AutomationProperties.AutomationId="DialogSaveButton"
                                              Margin="0,0,8,0"
                                              Content="Save"
                                              Command="{x:Static overlaySurface:NaviusOverlaySurfaceBase.CloseCommand}" />
                        <navius:NaviusButton AutomationProperties.AutomationId="DialogCloseButton"
                                              Content="Close"
                                              Command="{x:Static overlaySurface:NaviusOverlaySurfaceBase.CloseCommand}" />
                    </StackPanel>
                </StackPanel>
            </dialog:NaviusDialog>
        </overlaySurface:NaviusOverlayLayer>
    </Grid>
</UserControl>
