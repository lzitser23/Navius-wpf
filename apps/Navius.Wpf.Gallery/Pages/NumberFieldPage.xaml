<UserControl x:Class="Navius.Wpf.Gallery.Pages.NumberFieldPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/NumberField.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="NumberField" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Default (0-10, step 1)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusNumberField AutomationProperties.AutomationId="DefaultField"
                                   Width="160" HorizontalAlignment="Left"
                                   Minimum="0" Maximum="10" Value="4" Margin="0,0,0,16" />

        <TextBlock Text="Step 5, LargeStep 25" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusNumberField AutomationProperties.AutomationId="SteppedField"
                                   Width="160" HorizontalAlignment="Left"
                                   Minimum="0" Maximum="100" Step="5" LargeStep="25" Value="10" Margin="0,0,0,16" />

        <TextBlock Text="Formatted (0.##)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusNumberField AutomationProperties.AutomationId="FormattedField"
                                   Width="160" HorizontalAlignment="Left"
                                   Minimum="0" Maximum="10" Step="0.5" Format="0.##" Value="2.5" Margin="0,0,0,16" />

        <TextBlock Text="Read-only" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusNumberField AutomationProperties.AutomationId="ReadOnlyField"
                                   Width="160" HorizontalAlignment="Left"
                                   ReadOnly="True" Value="7" Margin="0,0,0,16" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusNumberField AutomationProperties.AutomationId="DisabledField"
                                   Width="160" HorizontalAlignment="Left"
                                   IsEnabled="False" Value="3" />
    </StackPanel>
</UserControl>
