<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Navius brand tokens, dark. Values mirror navius-docs Styles/app.css. -->
    <sys:String x:Key="Navius.Tokens.Theme">Dark</sys:String>

    <SolidColorBrush x:Key="Navius.Background" Color="#161513" />
    <SolidColorBrush x:Key="Navius.Foreground" Color="#F0EFEC" />
    <SolidColorBrush x:Key="Navius.Card" Color="#201F1C" />
    <SolidColorBrush x:Key="Navius.CardForeground" Color="#F0EFEC" />
    <SolidColorBrush x:Key="Navius.Popover" Color="#201F1C" />
    <SolidColorBrush x:Key="Navius.PopoverForeground" Color="#F0EFEC" />
    <SolidColorBrush x:Key="Navius.Primary" Color="#F0EFEC" />
    <SolidColorBrush x:Key="Navius.PrimaryForeground" Color="#161513" />
    <SolidColorBrush x:Key="Navius.Secondary" Color="#2C2B27" />
    <SolidColorBrush x:Key="Navius.SecondaryForeground" Color="#F0EFEC" />
    <SolidColorBrush x:Key="Navius.Muted" Color="#211F1C" />
    <SolidColorBrush x:Key="Navius.MutedForeground" Color="#98958E" />
    <SolidColorBrush x:Key="Navius.Accent" Color="#2C2B27" />
    <SolidColorBrush x:Key="Navius.AccentForeground" Color="#F0EFEC" />
    <!-- web token is oklch(0.704 0.191 22.216); sRGB equivalent -->
    <SolidColorBrush x:Key="Navius.Destructive" Color="#FF6467" />
    <SolidColorBrush x:Key="Navius.DestructiveForeground" Color="#161513" />
    <SolidColorBrush x:Key="Navius.Border" Color="#2D2B27" />
    <SolidColorBrush x:Key="Navius.Input" Color="#3B3935" />
    <SolidColorBrush x:Key="Navius.Ring" Color="#F0EFEC" />

    <CornerRadius x:Key="Navius.Radius.Small">4</CornerRadius>
    <CornerRadius x:Key="Navius.Radius.Control">6</CornerRadius>
    <CornerRadius x:Key="Navius.Radius.Card">8</CornerRadius>

</ResourceDictionary>
