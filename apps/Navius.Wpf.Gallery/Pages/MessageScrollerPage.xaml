<UserControl x:Class="Navius.Wpf.Gallery.Pages.MessageScrollerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             xmlns:ms="clr-namespace:Navius.Wpf.Primitives.Controls.MessageScroller;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             AutomationProperties.AutomationId="MessageScrollerDemo"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use
                     NaviusMessageScroller merge this dictionary themselves. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/MessageScroller.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top">
            <TextBlock Text="MessageScroller"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource Navius.Foreground}" />
            <TextBlock Margin="0,4,0,20"
                       Text="Never move the reader: appended messages auto-follow only while you are at the live edge; scrolling up disengages the follow and appended messages count toward the jump button instead. Prepending older history keeps your reading position fixed."
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />

            <navius:NaviusButton AutomationProperties.AutomationId="MessageScrollerAppendButton"
                                  Margin="0,0,0,8" HorizontalAlignment="Stretch"
                                  Content="Append a message" Click="OnAppendClick" />
            <navius:NaviusButton AutomationProperties.AutomationId="MessageScrollerAppendBurstButton"
                                  Margin="0,0,0,8" HorizontalAlignment="Stretch"
                                  Content="Append 5 messages" Click="OnAppendBurstClick" />
            <navius:NaviusButton AutomationProperties.AutomationId="MessageScrollerPrependButton"
                                  Margin="0,0,0,8" HorizontalAlignment="Stretch"
                                  Content="Prepend older history (anchor holds)" Click="OnPrependClick" />
            <navius:NaviusButton AutomationProperties.AutomationId="MessageScrollerClearButton"
                                  Margin="0,0,0,8" HorizontalAlignment="Stretch"
                                  Content="Clear" Click="OnClearClick" />

            <TextBlock x:Name="StateText"
                       Margin="0,12,0,0"
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Column="2"
                BorderBrush="{DynamicResource Navius.Border}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Navius.Radius.Card}">
            <ms:NaviusMessageScroller x:Name="Scroller"
                                      AutomationProperties.AutomationId="MessageScrollerScroller"
                                      AutomationProperties.Name="Messages"
                                      AutoScroll="True">
                <ms:NaviusMessageScroller.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Padding="12,8"
                                Background="{DynamicResource Navius.Card}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Navius.Radius.Control}">
                            <TextBlock Text="{Binding}"
                                       Foreground="{DynamicResource Navius.CardForeground}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </DataTemplate>
                </ms:NaviusMessageScroller.ItemTemplate>
            </ms:NaviusMessageScroller>
        </Border>
    </Grid>
</UserControl>
