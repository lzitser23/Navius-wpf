<UserControl x:Class="Navius.Wpf.Gallery.Pages.RadioGroupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:radio="clr-namespace:Navius.Wpf.Primitives.Controls.RadioGroup;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <StackPanel Margin="24">
        <TextBlock Text="RadioGroup" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Default (no selection; arrow keys / Home / End rove)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <radio:NaviusRadioGroup Margin="0,0,0,16">
            <StackPanel>
                <radio:NaviusRadioGroupItem Value="a" Content="Option A" Margin="0,0,0,4" />
                <radio:NaviusRadioGroupItem Value="b" Content="Option B" Margin="0,0,0,4" />
                <radio:NaviusRadioGroupItem Value="c" Content="Option C" />
            </StackPanel>
        </radio:NaviusRadioGroup>

        <TextBlock Text="Pre-selected" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <radio:NaviusRadioGroup Value="b" Margin="0,0,0,16">
            <StackPanel>
                <radio:NaviusRadioGroupItem Value="a" Content="Option A" Margin="0,0,0,4" />
                <radio:NaviusRadioGroupItem Value="b" Content="Option B" Margin="0,0,0,4" />
                <radio:NaviusRadioGroupItem Value="c" Content="Option C" />
            </StackPanel>
        </radio:NaviusRadioGroup>

        <TextBlock Text="Disabled group" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <radio:NaviusRadioGroup Value="a" IsEnabled="False" Margin="0,0,0,16">
            <StackPanel>
                <radio:NaviusRadioGroupItem Value="a" Content="Option A" Margin="0,0,0,4" />
                <radio:NaviusRadioGroupItem Value="b" Content="Option B" />
            </StackPanel>
        </radio:NaviusRadioGroup>

        <TextBlock Text="Read-only item (focusable, locked selected)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <radio:NaviusRadioGroup Value="a">
            <StackPanel>
                <radio:NaviusRadioGroupItem Value="a" Content="Locked in" ReadOnly="True" Margin="0,0,0,4" />
                <radio:NaviusRadioGroupItem Value="b" Content="Option B" />
            </StackPanel>
        </radio:NaviusRadioGroup>
    </StackPanel>
</UserControl>
