<UserControl x:Class="Navius.Wpf.Gallery.Pages.HighContrastPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="HighContrastDemo"
             Background="{DynamicResource Navius.Background}">
    <!--
        Self-contained, no navigation wiring (MainWindow is orchestrator-owned this wave -- see the
        task brief). Demonstrates NaviusTheme.HighContrast: a button applies it (and syncs live to
        SystemParameters.HighContrast for the rest of this run), a second button restores Light, and
        a small set of controls below shows the mapped tokens in use. See ADR-0007.
    -->
    <ScrollViewer Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640">
            <TextBlock Text="High contrast" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Navius.Foreground}" />
            <TextBlock Margin="0,4,0,24" MaxWidth="560"
                       Text="Every Navius.* brush remapped to a SystemColors *ColorKey via DynamicResource, so it tracks the OS palette live. A native-Windows obligation the web port never had -- see docs/adr/0007-high-contrast.md."
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Button x:Name="ApplyHighContrastButton"
                        AutomationProperties.AutomationId="ApplyHighContrast"
                        Content="Apply HighContrast"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Click="OnApplyHighContrastClick" />
                <Button x:Name="RestoreLightButton"
                        AutomationProperties.AutomationId="RestoreLight"
                        Content="Restore Light"
                        Padding="12,6"
                        Click="OnRestoreLightClick" />
            </StackPanel>

            <TextBlock x:Name="CurrentThemeSummary"
                       AutomationProperties.AutomationId="HighContrastCurrentTheme"
                       Text="Current theme: Light"
                       Foreground="{DynamicResource Navius.MutedForeground}"
                       Margin="0,0,0,24" />

            <Border Background="{DynamicResource Navius.Card}"
                    BorderBrush="{DynamicResource Navius.Border}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Navius.Radius.Card}"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Card surface" FontWeight="SemiBold" Foreground="{DynamicResource Navius.CardForeground}" Margin="0,0,0,8" />
                    <Button Content="Primary" Background="{DynamicResource Navius.Primary}" Foreground="{DynamicResource Navius.PrimaryForeground}" Padding="10,4" Margin="0,0,0,8" HorizontalAlignment="Left" />
                    <Button Content="Secondary" Background="{DynamicResource Navius.Secondary}" Foreground="{DynamicResource Navius.SecondaryForeground}" Padding="10,4" Margin="0,0,0,8" HorizontalAlignment="Left" />
                    <Border Background="{DynamicResource Navius.Destructive}" Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock Text="Destructive" Foreground="{DynamicResource Navius.DestructiveForeground}" />
                    </Border>
                    <TextBlock Text="Muted foreground text" Foreground="{DynamicResource Navius.MutedForeground}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
