<UserControl x:Class="Navius.Wpf.Gallery.Pages.SelectPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use the
                     Select family merge this dictionary themselves, same as MenuPage does
                     for Menu.xaml. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Select.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24" HorizontalAlignment="Left">
        <TextBlock Text="Select" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />
        <TextBlock Margin="0,0,0,16" MaxWidth="420"
                   Text="A listbox-select (NaviusSelect&lt;T&gt;): click or press Enter/Space/ArrowDown to open, arrow keys and type-ahead to highlight, Enter/Space or click to commit, Escape or an outside click to dismiss. The second control is Multiple: toggling keeps the popup open."
                   Foreground="{DynamicResource Navius.MutedForeground}" TextWrapping="Wrap" />

        <TextBlock Text="Single select" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <!-- NaviusSelect<string> is a generic type; the instances are built in code-behind
             (SelectPage.xaml.cs) and dropped into these hosts, which is less fragile than
             x:TypeArguments markup. The AutomationId is set on the real control there. -->
        <ContentControl x:Name="SingleHost" HorizontalAlignment="Left" Margin="0,0,0,20" />

        <TextBlock Text="Multiple select" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <ContentControl x:Name="MultiHost" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
