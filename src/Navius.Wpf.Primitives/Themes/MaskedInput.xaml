<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls.MaskedInput">

    <!--
        Not merged into Generic.xaml (out of scope: another family owns that file). Pages that use
        NaviusMaskedInput merge this dictionary themselves, e.g.:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/MaskedInput.xaml" />

        TextBox-derived (see NaviusMaskedInput.cs remarks): the template is the same Border +
        PART_ContentHost chrome NaviusInput (Field family) uses, since masking adds no extra visual
        parts, only a Text pipeline. Hairline border, one-ink brand, no shadows.
    -->

    <Style TargetType="{x:Type controls:NaviusMaskedInput}">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Background" Value="{DynamicResource Navius.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Input}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusMaskedInput}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <Trigger Property="Invalid" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource Navius.Destructive}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
