<UserControl x:Class="Navius.Wpf.Gallery.Pages.TagInputPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:taginput="clr-namespace:Navius.Wpf.Primitives.Controls.TagInput;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/TagInput.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="TagInput" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Default (Enter or comma commits; Backspace on empty pops)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <taginput:NaviusTagInput x:Name="DefaultTagInput"
                                 AutomationProperties.AutomationId="TagInputDemo"
                                 Width="320" HorizontalAlignment="Left"
                                 Placeholder="Add a tag..." Margin="0,0,0,16" />

        <TextBlock Text="Lowercased, max 4, no duplicates" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <taginput:NaviusTagInput x:Name="RuledTagInput"
                                 AutomationProperties.AutomationId="RuledTagInput"
                                 Width="320" HorizontalAlignment="Left"
                                 MaxTags="4" Placeholder="lowercase, 4 max" Margin="0,0,0,16" />

        <TextBlock Text="Commit on blur" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <taginput:NaviusTagInput AutomationProperties.AutomationId="BlurTagInput"
                                 Width="320" HorizontalAlignment="Left"
                                 AddOnBlur="True" Placeholder="Commits when you leave" Margin="0,0,0,16" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <taginput:NaviusTagInput x:Name="DisabledTagInput"
                                 AutomationProperties.AutomationId="DisabledTagInput"
                                 Width="320" HorizontalAlignment="Left"
                                 IsEnabled="False" />
    </StackPanel>
</UserControl>
