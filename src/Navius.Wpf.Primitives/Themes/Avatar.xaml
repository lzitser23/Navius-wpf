<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Navius.Wpf.Primitives.Controls">

    <Style TargetType="{x:Type controls:NaviusAvatar}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{DynamicResource Navius.Secondary}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.SecondaryForeground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NaviusAvatar}">
                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="9999"
                        ClipToBounds="True">
                        <Grid>
                            <ContentPresenter
                                x:Name="FallbackPresenter"
                                Content="{TemplateBinding Fallback}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                            <Image
                                x:Name="PART_Image"
                                Stretch="UniformToFill"
                                Opacity="0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFallbackVisible" Value="False">
                            <Setter TargetName="FallbackPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Status" Value="Loaded">
                            <Setter TargetName="PART_Image" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
