<UserControl x:Class="Navius.Wpf.Gallery.Pages.CurrencyInputPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:currency="clr-namespace:Navius.Wpf.Primitives.Controls.CurrencyInput;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/CurrencyInput.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="CurrencyInput" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="USD (current culture grouping)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <currency:NaviusCurrencyInput AutomationProperties.AutomationId="CurrencyInputDemo"
                                      Width="180" HorizontalAlignment="Left"
                                      Currency="USD" Margin="0,0,0,16" />

        <TextBlock Text="EUR, negatives allowed" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <currency:NaviusCurrencyInput AutomationProperties.AutomationId="EurCurrencyInput"
                                      Width="180" HorizontalAlignment="Left"
                                      Currency="EUR" AllowNegative="True" Margin="0,0,0,16" />

        <TextBlock Text="Clamped 0-1000, committed on blur" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <currency:NaviusCurrencyInput AutomationProperties.AutomationId="ClampedCurrencyInput"
                                      Width="180" HorizontalAlignment="Left"
                                      Currency="USD" Minimum="0" Maximum="1000" Margin="0,0,0,16" />

        <TextBlock Text="No symbol, whole units only" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <currency:NaviusCurrencyInput AutomationProperties.AutomationId="PlainCurrencyInput"
                                      Width="180" HorizontalAlignment="Left"
                                      ShowSymbol="False" MinFractionDigits="0" MaxFractionDigits="0" Margin="0,0,0,16" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <currency:NaviusCurrencyInput AutomationProperties.AutomationId="DisabledCurrencyInput"
                                      Width="180" HorizontalAlignment="Left"
                                      Currency="USD" DefaultValue="1234.5" IsEnabled="False" />
    </StackPanel>
</UserControl>
