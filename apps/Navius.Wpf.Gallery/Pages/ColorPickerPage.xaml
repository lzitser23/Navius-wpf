<UserControl x:Class="Navius.Wpf.Gallery.Pages.ColorPickerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/ColorPicker.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="ColorPicker"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="420"
                   Text="A saturation/brightness area, hue slider, optional alpha slider, hex field, and preset swatches over one HSVA model."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="0,0,32,0">
                <TextBlock Text="hex format, with swatches" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
                <navius:NaviusColorPicker AutomationProperties.AutomationId="ColorPickerDemo"
                                           DefaultValue="#3B82F6">
                    <navius:NaviusColorPicker.Colors>
                        <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=System.Runtime">
                            <sys:String>#EF4444</sys:String>
                            <sys:String>#F97316</sys:String>
                            <sys:String>#EAB308</sys:String>
                            <sys:String>#22C55E</sys:String>
                            <sys:String>#3B82F6</sys:String>
                            <sys:String>#8B5CF6</sys:String>
                        </x:Array>
                    </navius:NaviusColorPicker.Colors>
                </navius:NaviusColorPicker>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="rgba format, alpha enabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
                <navius:NaviusColorPicker AutomationProperties.AutomationId="AlphaColorPicker"
                                           Format="rgba" AlphaEnabled="True" DefaultValue="rgba(139, 92, 246, 0.75)" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
