<UserControl x:Class="Navius.Wpf.Gallery.Pages.ScrollAreaPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/ScrollArea.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="ScrollArea"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="480"
                   Text="Overlay scrollbars: thin ink thumb on a transparent track, floating over the content edge. Hover the area or scroll to reveal the bars; they fade out after ScrollHideDelay (600ms default) of inactivity."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="0,0,32,0">
                <TextBlock Text="Vertical overflow" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
                <Border BorderBrush="{DynamicResource Navius.Border}" BorderThickness="1" CornerRadius="{DynamicResource Navius.Radius.Control}">
                    <navius:NaviusScrollArea AutomationProperties.AutomationId="VerticalScrollArea"
                                              Width="220" Height="180">
                        <StackPanel Margin="8">
                            <TextBlock Text="Item 0" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 1" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 2" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 3" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 4" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 5" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 6" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 7" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 8" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 9" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 10" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 11" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 12" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 13" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                            <TextBlock Text="Item 14" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                        </StackPanel>
                    </navius:NaviusScrollArea>
                </Border>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Both axes overflow (Corner part)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
                <Border BorderBrush="{DynamicResource Navius.Border}" BorderThickness="1" CornerRadius="{DynamicResource Navius.Radius.Control}">
                    <navius:NaviusScrollArea AutomationProperties.AutomationId="BothAxesScrollArea"
                                              Width="220" Height="180"
                                              HorizontalScrollBarVisibility="Auto">
                        <Border Width="600" Height="500" Margin="8"
                                Background="{DynamicResource Navius.Muted}"
                                CornerRadius="{DynamicResource Navius.Radius.Small}">
                            <TextBlock Text="600x500 content, scrolls both ways"
                                       Foreground="{DynamicResource Navius.MutedForeground}"
                                       Margin="12" TextWrapping="Wrap" />
                        </Border>
                    </navius:NaviusScrollArea>
                </Border>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="ScrollHideDelay = 100ms" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,24,0,4" />
        <Border BorderBrush="{DynamicResource Navius.Border}" BorderThickness="1" CornerRadius="{DynamicResource Navius.Radius.Control}" HorizontalAlignment="Left">
            <navius:NaviusScrollArea AutomationProperties.AutomationId="FastHideScrollArea"
                                      Width="220" Height="120" ScrollHideDelay="100">
                <StackPanel Margin="8">
                    <TextBlock Text="Scroll me, bars hide fast" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" TextWrapping="Wrap" />
                    <TextBlock Text="Line 2" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                    <TextBlock Text="Line 3" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                    <TextBlock Text="Line 4" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                    <TextBlock Text="Line 5" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                    <TextBlock Text="Line 6" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                    <TextBlock Text="Line 7" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                    <TextBlock Text="Line 8" Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,8" />
                </StackPanel>
            </navius:NaviusScrollArea>
        </Border>
    </StackPanel>
</UserControl>
