<UserControl x:Class="Navius.Wpf.Gallery.Pages.SliderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Slider.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Slider"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="420"
                   Text="Single-thumb only for M1. Arrow/Shift+Arrow/PageUp/PageDown/Home/End all work; multi-thumb range is deferred."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <TextBlock Text="Default" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusSlider AutomationProperties.AutomationId="DefaultSlider"
                              Width="240" HorizontalAlignment="Left"
                              Minimum="0" Maximum="100" Value="40" Margin="0,0,0,20" />

        <TextBlock Text="Step 10, LargeStep 20" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusSlider AutomationProperties.AutomationId="SteppedSlider"
                              Width="240" HorizontalAlignment="Left"
                              Minimum="0" Maximum="100" Step="10" LargeStep="20" Value="30" Margin="0,0,0,20" />

        <TextBlock Text="Inverted" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusSlider AutomationProperties.AutomationId="InvertedSlider"
                              Width="240" HorizontalAlignment="Left"
                              Minimum="0" Maximum="100" Value="70" IsDirectionReversed="True" Margin="0,0,0,20" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusSlider AutomationProperties.AutomationId="DisabledSlider"
                              Width="240" HorizontalAlignment="Left"
                              Minimum="0" Maximum="100" Value="55" IsEnabled="False" Margin="0,0,0,20" />

        <TextBlock Text="Vertical" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <navius:NaviusSlider AutomationProperties.AutomationId="VerticalSlider"
                              Height="160" Orientation="Vertical" HorizontalAlignment="Left"
                              Minimum="0" Maximum="100" Value="60" />
    </StackPanel>
</UserControl>
