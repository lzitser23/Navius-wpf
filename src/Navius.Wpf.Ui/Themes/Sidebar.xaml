<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sidebar="clr-namespace:Navius.Wpf.Ui.Sidebar">

    <!--
        Not merged into Generic.xaml (the orchestrator owns that file). Consumers merge this
        dictionary themselves:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Sidebar.xaml" />
    -->

    <Style TargetType="{x:Type sidebar:NaviusSidebar}">
        <Setter Property="Background" Value="{DynamicResource Navius.Card}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sidebar:NaviusSidebar}">
                    <Border
                        x:Name="PART_Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource Navius.Border}"
                        BorderThickness="0,0,1,0"
                        HorizontalAlignment="Left">
                        <DockPanel LastChildFill="True">
                            <ContentPresenter
                                DockPanel.Dock="Top"
                                Margin="12,12,12,8"
                                Content="{TemplateBinding HeaderContent}" />

                            <StackPanel DockPanel.Dock="Bottom" Margin="8">
                                <ContentPresenter Margin="4,0,4,8" Content="{TemplateBinding FooterContent}" />
                                <Button Command="{x:Static sidebar:NaviusSidebar.ToggleCollapsedCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,7"
                                        Cursor="Hand">
                                    <!--
                                        The visible "Collapse" TextBlock is hidden when IsCollapsed (see the
                                        ToggleLabel DataTrigger below), so the button would otherwise have no
                                        accessible name once collapsed. AutomationProperties.Name flips with
                                        state so assistive tech always announces the action this press performs
                                        (issue #28).
                                    -->
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="AutomationProperties.Name" Value="Collapse sidebar" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding RelativeSource="{RelativeSource Self}" Path="(sidebar:NaviusSidebar.IsCollapsed)" />
                                                    </DataTrigger.Binding>
                                                    <Setter Property="AutomationProperties.Name" Value="Expand sidebar" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ToggleBg" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource Navius.Radius.Control}">
                                                <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                                    <Path x:Name="Chevron"
                                                          Data="M 6,0 L 0,4 L 6,8"
                                                          VerticalAlignment="Center"
                                                          Stroke="{DynamicResource Navius.MutedForeground}"
                                                          StrokeThickness="1.4"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                                    <TextBlock x:Name="ToggleLabel" Margin="10,0,0,0" VerticalAlignment="Center"
                                                               Text="Collapse" Foreground="{DynamicResource Navius.MutedForeground}" FontSize="13" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ToggleBg" Property="Background" Value="{DynamicResource Navius.Muted}" />
                                                </Trigger>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="(sidebar:NaviusSidebar.IsCollapsed)" />
                                                    </DataTrigger.Binding>
                                                    <Setter TargetName="Chevron" Property="Data" Value="M 0,0 L 6,4 L 0,8" />
                                                    <Setter TargetName="ToggleLabel" Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter Margin="8,4" KeyboardNavigation.DirectionalNavigation="Contained" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sidebar:NaviusSidebarSection}">
        <Setter Property="Margin" Value="0,4,0,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sidebar:NaviusSidebarSection}">
                    <StackPanel>
                        <ContentPresenter
                            x:Name="HeaderPresenter"
                            Margin="8,0,8,4"
                            ContentSource="Header"
                            TextElement.FontSize="11"
                            TextElement.FontWeight="SemiBold"
                            TextElement.Foreground="{DynamicResource Navius.MutedForeground}" />
                        <ItemsPresenter />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <!-- Self, not TemplatedParent: same null-templated-parent trap as the
                             NaviusSidebarItem label trigger below (issue #28 follow-up). -->
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <Binding RelativeSource="{RelativeSource Self}" Path="(sidebar:NaviusSidebar.IsCollapsed)" />
                            </DataTrigger.Binding>
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sidebar:NaviusSidebarItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ToolTip" Value="{Binding Content, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sidebar:NaviusSidebarItem}">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource Navius.Radius.Control}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Rectangle x:Name="ActiveBar" Grid.Column="0" Width="3" Fill="{DynamicResource Navius.Foreground}" Visibility="Collapsed" RadiusX="1.5" RadiusY="1.5" />

                            <ContentPresenter
                                x:Name="IconPresenter"
                                Grid.Column="1"
                                Width="20" Height="20"
                                Margin="{TemplateBinding Padding}"
                                Content="{TemplateBinding Icon}" />

                            <ContentPresenter
                                x:Name="LabelPresenter"
                                Grid.Column="2"
                                Margin="0,7,10,7"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Navius.Muted}" />
                        </Trigger>
                        <Trigger Property="IsActive" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Navius.Accent}" />
                            <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Navius.Muted}" />
                        </Trigger>
                        <!--
                            Self, not TemplatedParent: for a template-trigger condition the binding's
                            anchor is the templated control itself, so TemplatedParent resolved the
                            ITEM's templated parent (null for directly-authored items) and this
                            trigger never fired. Self reads the item's own inherited IsCollapsed
                            (issue #28 follow-up).
                        -->
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <Binding RelativeSource="{RelativeSource Self}" Path="(sidebar:NaviusSidebar.IsCollapsed)" />
                            </DataTrigger.Binding>
                            <Setter TargetName="LabelPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="IconPresenter" Property="HorizontalAlignment" Value="Center" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
