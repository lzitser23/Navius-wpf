<UserControl x:Class="Navius.Wpf.Gallery.Pages.AccordionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:accordion="clr-namespace:Navius.Wpf.Primitives.Controls.Accordion;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Self-contained: merges its own family theme directly, since Generic.xaml
                     is owned by a concurrent wave this cycle and is not touched here. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Accordion.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel Margin="24">
        <TextBlock Text="Accordion" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <TextBlock Text="Single, not collapsible (default; one section always stays open)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <accordion:NaviusAccordion Type="single" Value="a" Width="360" HorizontalAlignment="Left" Margin="0,0,0,24">
            <StackPanel>
                <accordion:NaviusAccordionItem Value="a">
                    <StackPanel>
                        <accordion:NaviusAccordionHeader>
                            <accordion:NaviusAccordionTrigger Content="Is it accessible?" />
                        </accordion:NaviusAccordionHeader>
                        <accordion:NaviusAccordionPanel>
                            <TextBlock TextWrapping="Wrap" Margin="4,0,4,12"
                                       Foreground="{DynamicResource Navius.MutedForeground}"
                                       Text="Yes. It follows the WAI-ARIA accordion pattern." />
                        </accordion:NaviusAccordionPanel>
                    </StackPanel>
                </accordion:NaviusAccordionItem>
                <accordion:NaviusAccordionItem Value="b">
                    <StackPanel>
                        <accordion:NaviusAccordionHeader>
                            <accordion:NaviusAccordionTrigger Content="Is it styled?" />
                        </accordion:NaviusAccordionHeader>
                        <accordion:NaviusAccordionPanel>
                            <TextBlock TextWrapping="Wrap" Margin="4,0,4,12"
                                       Foreground="{DynamicResource Navius.MutedForeground}"
                                       Text="Yes. Token-driven, hairline borders, one-ink brand." />
                        </accordion:NaviusAccordionPanel>
                    </StackPanel>
                </accordion:NaviusAccordionItem>
                <accordion:NaviusAccordionItem Value="c" IsEnabled="False">
                    <StackPanel>
                        <accordion:NaviusAccordionHeader>
                            <accordion:NaviusAccordionTrigger Content="Disabled section" />
                        </accordion:NaviusAccordionHeader>
                        <accordion:NaviusAccordionPanel>
                            <TextBlock Text="Unreachable." Margin="4,0,4,12" />
                        </accordion:NaviusAccordionPanel>
                    </StackPanel>
                </accordion:NaviusAccordionItem>
            </StackPanel>
        </accordion:NaviusAccordion>

        <TextBlock Text="Multiple (several sections can be open at once)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <accordion:NaviusAccordion Type="multiple" Width="360" HorizontalAlignment="Left">
            <StackPanel>
                <accordion:NaviusAccordionItem Value="x">
                    <StackPanel>
                        <accordion:NaviusAccordionHeader>
                            <accordion:NaviusAccordionTrigger Content="Section X" />
                        </accordion:NaviusAccordionHeader>
                        <accordion:NaviusAccordionPanel>
                            <TextBlock Text="X content." Margin="4,0,4,12" Foreground="{DynamicResource Navius.MutedForeground}" />
                        </accordion:NaviusAccordionPanel>
                    </StackPanel>
                </accordion:NaviusAccordionItem>
                <accordion:NaviusAccordionItem Value="y">
                    <StackPanel>
                        <accordion:NaviusAccordionHeader>
                            <accordion:NaviusAccordionTrigger Content="Section Y" />
                        </accordion:NaviusAccordionHeader>
                        <accordion:NaviusAccordionPanel>
                            <TextBlock Text="Y content." Margin="4,0,4,12" Foreground="{DynamicResource Navius.MutedForeground}" />
                        </accordion:NaviusAccordionPanel>
                    </StackPanel>
                </accordion:NaviusAccordionItem>
            </StackPanel>
        </accordion:NaviusAccordion>
    </StackPanel>
</UserControl>
