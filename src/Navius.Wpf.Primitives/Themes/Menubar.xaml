<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:menubar="clr-namespace:Navius.Wpf.Primitives.Controls.Menubar">

    <!-- NaviusMenubar: the horizontal (or vertical) bar itself. -->
    <Style TargetType="{x:Type menubar:NaviusMenubar}">
        <Setter Property="Background" Value="{DynamicResource Navius.Popover}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" IsItemsHost="True" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubar}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        Padding="{TemplateBinding Padding}">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenubarMenu: top-level trigger row + its floating submenu popup, collapsed into one MenuItem. -->
    <Style TargetType="{x:Type menubar:NaviusMenubarMenu}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubarMenu}">
                    <Grid>
                        <Border x:Name="Row"
                                Background="Transparent"
                                CornerRadius="{DynamicResource Navius.Radius.Small}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                ContentSource="Header"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Border>
                        <Popup x:Name="SubmenuPopup"
                               Placement="Bottom"
                               HorizontalOffset="0"
                               VerticalOffset="2"
                               IsOpen="{Binding Path=IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               AllowsTransparency="True"
                               Focusable="False"
                               StaysOpen="False"
                               PopupAnimation="Fade">
                            <Border
                                Background="{DynamicResource Navius.Popover}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Navius.Radius.Control}"
                                Padding="4"
                                MinWidth="180"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{DynamicResource Navius.PopoverForeground}">
                                <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- data-popup-open / hover -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <!-- data-disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenubarSubTrigger: nested submenu header (collapses Sub + SubTrigger + SubContent). -->
    <Style TargetType="{x:Type menubar:NaviusMenubarSubTrigger}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubarSubTrigger}">
                    <Grid>
                        <Border x:Name="Row"
                                Background="Transparent"
                                CornerRadius="{DynamicResource Navius.Radius.Small}"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="&#9656;" Margin="12,0,0,0"
                                           VerticalAlignment="Center" Foreground="{DynamicResource Navius.MutedForeground}" />
                                <ContentPresenter
                                    ContentSource="Header"
                                    VerticalAlignment="Center"
                                    RecognizesAccessKey="True" />
                            </DockPanel>
                        </Border>
                        <Popup x:Name="SubmenuPopup"
                               Placement="Right"
                               HorizontalOffset="-2"
                               VerticalOffset="-6"
                               IsOpen="{Binding Path=IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               AllowsTransparency="True"
                               Focusable="False"
                               StaysOpen="False"
                               PopupAnimation="Fade">
                            <Border
                                Background="{DynamicResource Navius.Popover}"
                                BorderBrush="{DynamicResource Navius.Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Navius.Radius.Control}"
                                Padding="4"
                                MinWidth="160"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{DynamicResource Navius.PopoverForeground}">
                                <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenubarItem: plain leaf row. -->
    <Style TargetType="{x:Type menubar:NaviusMenubarItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubarItem}">
                    <Border x:Name="Row"
                            Background="Transparent"
                            CornerRadius="{DynamicResource Navius.Radius.Small}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenubarCheckboxItem: leaf row with a tri-state glyph column (own Checked DP, see class remarks). -->
    <Style TargetType="{x:Type menubar:NaviusMenubarCheckboxItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubarCheckboxItem}">
                    <Border x:Name="Row"
                            Background="Transparent"
                            CornerRadius="{DynamicResource Navius.Radius.Small}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="14" Height="14" Margin="0,0,8,0">
                                <Path x:Name="CheckGlyph"
                                      Data="M 1,5 L 4,8 L 9,1"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                                <Rectangle x:Name="IndeterminateGlyph"
                                           Width="9" Height="1.6"
                                           Fill="{TemplateBinding Foreground}"
                                           Visibility="Collapsed" />
                            </Grid>
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <!-- data-checked -->
                        <Trigger Property="Checked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- data-indeterminate -->
                        <Trigger Property="Checked" Value="{x:Null}">
                            <Setter TargetName="IndeterminateGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenubarRadioItem: leaf row with a radio-dot glyph column (native IsChecked, synced from Group). -->
    <Style TargetType="{x:Type menubar:NaviusMenubarRadioItem}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.PopoverForeground}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubarRadioItem}">
                    <Border x:Name="Row"
                            Background="Transparent"
                            CornerRadius="{DynamicResource Navius.Radius.Small}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="14" Height="14" Margin="0,0,8,0">
                                <Ellipse x:Name="Dot"
                                         Width="6" Height="6"
                                         Fill="{TemplateBinding Foreground}"
                                         Visibility="Collapsed" />
                            </Grid>
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{DynamicResource Navius.Accent}" />
                        </Trigger>
                        <!-- data-checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenubarLabel: non-interactive muted heading. -->
    <Style TargetType="{x:Type menubar:NaviusMenubarLabel}">
        <Setter Property="Foreground" Value="{DynamicResource Navius.MutedForeground}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubarLabel}">
                    <Border Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NaviusMenubarSeparator: thin token-colored divider. -->
    <Style TargetType="{x:Type menubar:NaviusMenubarSeparator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type menubar:NaviusMenubarSeparator}">
                    <Border Height="1" Margin="4,4" Background="{DynamicResource Navius.Border}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
