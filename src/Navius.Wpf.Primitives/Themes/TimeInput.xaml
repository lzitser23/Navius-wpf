<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:timeInput="clr-namespace:Navius.Wpf.Primitives.Controls.TimeInput">

    <!--
        Not merged into Generic.xaml (out of scope for this wave; same precedent as
        Themes/Select.xaml). Pages that use TimeInput merge this dictionary themselves, alongside
        Themes/DateInput.xaml for the shared NaviusFieldSegment style:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/DateInput.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/TimeInput.xaml" />

        NaviusFieldSegment's style lives in DateInput.xaml (the family that introduces the shared
        part); this dictionary only styles the TimeInput root, matching the shared-segment reuse
        documented in time-input.md and NaviusTimeInput.cs's remarks.
    -->

    <!-- Root (contract's NaviusTimeInput, role="group"): hairline border + PART_Segments row built in code. -->
    <Style TargetType="{x:Type timeInput:NaviusTimeInput}">
        <Setter Property="Background" Value="{DynamicResource Navius.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Input}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type timeInput:NaviusTimeInput}">
                    <Border
                        x:Name="Group"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        Padding="8,6">
                        <StackPanel x:Name="PART_Segments" Orientation="Horizontal" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Group" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <!-- data-invalid -->
                        <Trigger Property="IsInvalidState" Value="True">
                            <Setter TargetName="Group" Property="BorderBrush" Value="{DynamicResource Navius.Destructive}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
