<UserControl x:Class="Navius.Wpf.Gallery.Pages.GatePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives">
    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="M1 gate: spring-animated anchored popup"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Text="Opens on the anchored positioner, animates in on a baked spring, focus is trapped, Esc and outside-click dismiss."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" MaxWidth="420" Margin="0,4,0,4" />
        <TextBlock x:Name="PopupState"
                   AutomationProperties.AutomationId="GatePopupState"
                   Text="Closed"
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   Margin="0,0,0,16" />
        <navius:NaviusButton x:Name="OpenButton"
                             AutomationProperties.AutomationId="GateOpen"
                             HorizontalAlignment="Left"
                             Content="Open popup"
                             Click="OnOpen" />
        <navius:NaviusAnchoredPopup x:Name="Popup"
                                    Anchor="{Binding ElementName=OpenButton}"
                                    Side="Bottom" Align="Start" SideOffset="8">
            <Border x:Name="PopupRoot"
                    Background="{DynamicResource Navius.Popover}"
                    BorderBrush="{DynamicResource Navius.Border}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Navius.Radius.Card}"
                    Padding="16" Width="260"
                    Focusable="True"
                    PreviewKeyDown="OnPopupKeyDown">
                <StackPanel>
                    <TextBlock Text="Anchored popup"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Navius.PopoverForeground}" />
                    <TextBox Margin="0,10,0,0" />
                    <navius:NaviusButton AutomationProperties.AutomationId="GateClose"
                                         Content="Close" Margin="0,12,0,0"
                                         HorizontalAlignment="Left"
                                         Click="OnClose" />
                </StackPanel>
            </Border>
        </navius:NaviusAnchoredPopup>
    </StackPanel>
</UserControl>
