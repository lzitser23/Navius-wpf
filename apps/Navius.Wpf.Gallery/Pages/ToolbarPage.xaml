<UserControl x:Class="Navius.Wpf.Gallery.Pages.ToolbarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             xmlns:toolbar="clr-namespace:Navius.Wpf.Primitives.Controls.Toolbar;assembly=Navius.Wpf.Primitives"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Self-contained: merges its own family themes directly, since Generic.xaml
                     is owned by a concurrent wave this cycle and is not touched here. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Toolbar.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/Separator.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="32" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Toolbar"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" />
        <TextBlock Margin="0,4,0,24"
                   MaxWidth="520"
                   Text="A flat container of focusable controls sharing a single roving Tab stop (WAI-ARIA APG Toolbar pattern). Tab into the toolbar once, then use arrow keys to move between buttons, the link, and the embedded toggle group; Space/Enter activate the focused item."
                   Foreground="{DynamicResource Navius.MutedForeground}"
                   TextWrapping="Wrap" />

        <TextBlock Text="Horizontal, mixed items" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <toolbar:NaviusToolbar AutomationProperties.AutomationId="ToolbarDemo"
                                Orientation="horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <toolbar:NaviusToolbarButton Content="Cut" Margin="0,0,4,0" />
                <toolbar:NaviusToolbarButton Content="Copy" Margin="0,0,4,0" />
                <toolbar:NaviusToolbarButton Content="Paste" Margin="0,0,8,0" />

                <navius:NaviusSeparator Orientation="Vertical" Height="24" Margin="0,0,8,0" />

                <toolbar:NaviusToolbarToggleGroup Type="multiple" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <toolbar:NaviusToolbarToggleItem Value="bold" Content="B" Margin="0,0,4,0" />
                        <toolbar:NaviusToolbarToggleItem Value="italic" Content="I" Margin="0,0,4,0" />
                        <toolbar:NaviusToolbarToggleItem Value="underline" Content="U" />
                    </StackPanel>
                </toolbar:NaviusToolbarToggleGroup>

                <navius:NaviusSeparator Orientation="Vertical" Height="24" Margin="0,0,8,0" />

                <toolbar:NaviusToolbarLink Content="Help" Uri="https://example.com/help" Margin="0,0,4,0" />
                <toolbar:NaviusToolbarButton Content="Disabled" Disabled="True" />
            </StackPanel>
        </toolbar:NaviusToolbar>

        <TextBlock Text="Vertical, Loop=False" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <toolbar:NaviusToolbar Orientation="vertical"
                                Loop="False"
                                HorizontalAlignment="Left">
            <StackPanel Orientation="Vertical">
                <toolbar:NaviusToolbarButton Content="One" Margin="0,0,0,4" />
                <toolbar:NaviusToolbarButton Content="Two" Margin="0,0,0,4" />
                <toolbar:NaviusToolbarButton Content="Three" />
            </StackPanel>
        </toolbar:NaviusToolbar>
    </StackPanel>
</UserControl>
