<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Not merged into Generic.xaml (the orchestrator owns that file). These are deliberately
        x:Key'd, not an implicit TargetType="GridSplitter" style: GridSplitter is a stock WPF type
        that a consumer may use unrelated to NaviusResizablePanelGroup elsewhere in the same merged
        scope, so an implicit style here would silently reskin those too.
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Ui;component/Themes/Resizable.xaml" />
    -->

    <Style x:Key="Navius.Splitter.Horizontal" TargetType="GridSplitter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="{TemplateBinding Background}">
                        <Rectangle x:Name="Line" Width="1" HorizontalAlignment="Center" Fill="{DynamicResource Navius.Border}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Line" Property="Width" Value="2" />
                            <Setter TargetName="Line" Property="Fill" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Line" Property="Width" Value="2" />
                            <Setter TargetName="Line" Property="Fill" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Navius.Splitter.Vertical" TargetType="GridSplitter" BasedOn="{StaticResource Navius.Splitter.Horizontal}">
        <Setter Property="Cursor" Value="SizeNS" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="{TemplateBinding Background}">
                        <Rectangle x:Name="Line" Height="1" VerticalAlignment="Center" Fill="{DynamicResource Navius.Border}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Line" Property="Height" Value="2" />
                            <Setter TargetName="Line" Property="Fill" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Line" Property="Height" Value="2" />
                            <Setter TargetName="Line" Property="Fill" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
