<UserControl x:Class="Navius.Wpf.Gallery.Pages.TimeInputPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:timeInput="clr-namespace:Navius.Wpf.Primitives.Controls.TimeInput;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); this page merges it directly.
                     DateInput.xaml is required too: NaviusFieldSegment (used by every segment cell
                     below) is styled there, shared across the DateInput/TimeInput/TimePicker family. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/DateInput.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/TimeInput.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="TimeInput" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />

        <!-- TimeOnly? has no XAML TypeConverter; pre-filled demo values are set from code-behind. -->

        <TextBlock Text="Default (minute granularity, 12h AM/PM)" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <timeInput:NaviusTimeInput x:Name="DefaultInput"
                                    AutomationProperties.AutomationId="TimeInputDemo"
                                    HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Pre-filled, second granularity" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <timeInput:NaviusTimeInput x:Name="SecondsInput"
                                    AutomationProperties.AutomationId="SecondsTimeInput"
                                    Granularity="second" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="24-hour cycle" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <timeInput:NaviusTimeInput x:Name="TwentyFourHourInput"
                                    AutomationProperties.AutomationId="TwentyFourHourTimeInput"
                                    HourCycle="24" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Minute step 15" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <timeInput:NaviusTimeInput x:Name="SteppedInput"
                                    AutomationProperties.AutomationId="SteppedTimeInput"
                                    MinuteStep="15" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Read-only" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <timeInput:NaviusTimeInput x:Name="ReadOnlyInput"
                                    AutomationProperties.AutomationId="ReadOnlyTimeInput"
                                    ReadOnly="True" HorizontalAlignment="Left" Margin="0,0,0,16" />

        <TextBlock Text="Disabled" Foreground="{DynamicResource Navius.MutedForeground}" Margin="0,0,0,4" />
        <timeInput:NaviusTimeInput x:Name="DisabledInput"
                                    AutomationProperties.AutomationId="DisabledTimeInput"
                                    IsEnabled="False" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
