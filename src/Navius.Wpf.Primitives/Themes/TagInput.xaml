<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
    xmlns:taginput="clr-namespace:Navius.Wpf.Primitives.Controls.TagInput">

    <!--
        Not merged into Generic.xaml (out of scope: another family owns that file). Pages that use
        NaviusTagInput merge this dictionary themselves, e.g.:
        <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/TagInput.xaml" />

        The chip visual language deliberately echoes Themes/Combobox.xaml's DefaultChip (Muted fill,
        hairline Border, Radius.Small, X remove button) but is OWNED here: this family must not
        reference or edit the Combobox dictionary. One-ink brand, no shadows.
    -->

    <!-- One chip. The remove button passes the whole chip VM as the command parameter; the root
         removes by the VM's Index (the committed list is never filtered, so index removal is safe,
         unlike the Combobox's by-value rule for filtered rows). -->
    <DataTemplate x:Key="Navius.TagInput.DefaultChip" DataType="{x:Type taginput:TagChipVm}">
        <Border
            x:Name="ChipRoot"
            Margin="0,0,4,2"
            Padding="6,2"
            Background="{DynamicResource Navius.Muted}"
            BorderBrush="{DynamicResource Navius.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Navius.Radius.Small}">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource Navius.Foreground}"
                    Text="{Binding Text}" />
                <Button
                    Margin="4,0,0,0"
                    Padding="2,0"
                    VerticalContentAlignment="Center"
                    automation:AutomationProperties.Name="{Binding RemoveName}"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{x:Static taginput:NaviusTagInput.RemoveTagCommand}"
                    CommandParameter="{Binding}"
                    Content="&#x2715;"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    Foreground="{DynamicResource Navius.MutedForeground}"
                    IsTabStop="False" />
            </StackPanel>
        </Border>
        <DataTemplate.Triggers>
            <!-- data-highlighted: the roving keyboard target reads as the accent surface. -->
            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                <Setter TargetName="ChipRoot" Property="Background" Value="{DynamicResource Navius.Accent}" />
                <Setter TargetName="ChipRoot" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style TargetType="{x:Type taginput:NaviusTagInput}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="Background" Value="{DynamicResource Navius.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Navius.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Navius.Input}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type taginput:NaviusTagInput}">
                    <Border
                        x:Name="Root"
                        Padding="8,4"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource Navius.Radius.Control}"
                        SnapsToDevicePixels="True">
                        <StackPanel>
                            <!-- The contract's layout-only List part: chips wrap above the field. -->
                            <ItemsControl
                                x:Name="PART_Chips"
                                Margin="0,2,0,2"
                                ItemTemplate="{StaticResource Navius.TagInput.DefaultChip}"
                                ItemsSource="{TemplateBinding Chips}"
                                Visibility="Visible">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Grid>
                                <TextBlock
                                    x:Name="PlaceholderText"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource Navius.MutedForeground}"
                                    IsHitTestVisible="False"
                                    Text="{TemplateBinding Placeholder}"
                                    Visibility="Collapsed" />
                                <TextBox
                                    x:Name="PART_Input"
                                    Padding="0"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CaretBrush="{DynamicResource Navius.Foreground}"
                                    FocusVisualStyle="{x:Null}"
                                    Foreground="{DynamicResource Navius.Foreground}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Navius.Ring}" />
                        </Trigger>
                        <Trigger Property="IsTagListEmpty" Value="True">
                            <Setter TargetName="PART_Chips" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            <Setter TargetName="PART_Input" Property="IsEnabled" Value="False" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition SourceName="PART_Input" Property="Text" Value="" />
                                <Condition Property="IsTagListEmpty" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
