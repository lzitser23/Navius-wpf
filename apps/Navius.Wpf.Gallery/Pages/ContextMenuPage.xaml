<UserControl x:Class="Navius.Wpf.Gallery.Pages.ContextMenuPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navius="clr-namespace:Navius.Wpf.Primitives.Controls;assembly=Navius.Wpf.Primitives"
             xmlns:menu="clr-namespace:Navius.Wpf.Primitives.Controls.Menus;assembly=Navius.Wpf.Primitives"
             xmlns:contextMenu="clr-namespace:Navius.Wpf.Primitives.Controls.ContextMenu;assembly=Navius.Wpf.Primitives"
             Background="{DynamicResource Navius.Background}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Not merged into Generic.xaml (out of scope here); pages that use the
                     ContextMenu family merge this dictionary themselves. It in turn merges
                     Themes/Menu.xaml, so the reused NaviusMenuItem/CheckboxItem/RadioItem
                     styles come along with it. -->
                <ResourceDictionary Source="pack://application:,,,/Navius.Wpf.Primitives;component/Themes/ContextMenu.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="24" HorizontalAlignment="Left">
        <TextBlock Text="ContextMenu" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Navius.Foreground}" Margin="0,0,0,12" />
        <TextBlock Margin="0,0,0,16" MaxWidth="420"
                   Text="Right-click (or press Shift+F10 / the Menu key while focused) inside the box below to open a cursor-anchored context menu. Reuses the same NaviusMenuItem/CheckboxItem/RadioItem stack as the Menu family."
                   Foreground="{DynamicResource Navius.MutedForeground}" TextWrapping="Wrap" />

        <contextMenu:NaviusContextMenuTrigger HorizontalAlignment="Left">
            <contextMenu:NaviusContextMenuTrigger.Menu>
                <contextMenu:NaviusContextMenuPopup x:Name="Popup" MinWidth="200">
                    <menu:NaviusMenuItem Header="Cut" InputGestureText="Ctrl+X" />
                    <menu:NaviusMenuItem Header="Copy" InputGestureText="Ctrl+C" />
                    <menu:NaviusMenuItem Header="Paste" InputGestureText="Ctrl+V" />
                    <menu:NaviusMenuItem Header="Disabled item" IsEnabled="False" />

                    <navius:NaviusSeparator Margin="4,4" />

                    <menu:NaviusMenuCheckboxItem Header="Word wrap" Checked="True" />
                    <menu:NaviusMenuCheckboxItem Header="Indeterminate example" Checked="{x:Null}" />

                    <navius:NaviusSeparator Margin="4,4" />

                    <menu:NaviusMenuGroupLabel Content="Encoding" />
                    <menu:NaviusMenuRadioItem Header="UTF-8" Value="utf8" GroupName="enc" IsChecked="True" />
                    <menu:NaviusMenuRadioItem Header="UTF-16" Value="utf16" GroupName="enc" />
                </contextMenu:NaviusContextMenuPopup>
            </contextMenu:NaviusContextMenuTrigger.Menu>

            <Border
                Width="360" Height="140"
                Background="{DynamicResource Navius.Card}"
                BorderBrush="{DynamicResource Navius.Border}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Navius.Radius.Card}">
                <TextBlock
                    Text="Right-click anywhere in this box"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Foreground="{DynamicResource Navius.CardForeground}" />
            </Border>
        </contextMenu:NaviusContextMenuTrigger>

        <navius:NaviusButton
            x:Name="OpenAtButton"
            Content="Open at a fixed point (RequestOpenAt API)"
            HorizontalAlignment="Left"
            Margin="0,16,0,0"
            Click="OnOpenAtClick" />
    </StackPanel>
</UserControl>
